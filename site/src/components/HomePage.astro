---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';
import platformsData from '../data/platforms.json';
import manifest from '../data/manifest.json';
import framingData from '../data/framing.json';
import mediaViolators from '../data/media_violators.json';
import findingsUk from '../data/findings_uk.json';
import auditData from '../data/llm_audit_results.json';
import modelsData from '../data/llm_models.json';
import sasResults from '../data/llm_sas_results.json';
// Fresh pipeline manifests (rewritten 2026-04)
import weatherPipeline from '../../../pipelines/weather/data/manifest.json';
import institutionsPipeline from '../../../pipelines/institutions/data/manifest.json';
import geodataPipeline from '../../../pipelines/geodata/data/manifest.json';
import telecomPipeline from '../../../pipelines/telecom/data/manifest.json';
import ipPipeline from '../../../pipelines/ip/data/manifest.json';
import mediaPipeline from '../../../pipelines/media/data/manifest.json';
import techInfraPipeline from '../../../pipelines/tech_infrastructure/data/manifest.json';
import wikipediaPipeline from '../../../pipelines/wikipedia/data/manifest.json';
import groundingData from '../data/grounding.json';
import corporaData from '../data/corpora.json';
// GitHub source links for each pipeline — used in section banners
const REPO = 'https://github.com/IvanDobrovolsky/crimeaisukraine';
const pipelineLinks = (name: string) => ({
  readme: `${REPO}/blob/main/pipelines/${name}/README.md`,
  manifest: `${REPO}/blob/main/pipelines/${name}/data/manifest.json`,
  scan: `${REPO}/blob/main/pipelines/${name}/scan.py`,
});

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
const m = manifest as any;

// Template variable replacer — substitutes {key} with manifest values
const sasResultsAny = sasResults as any;
const llmModelCount = 18  // 18 models with complete dual-tier audit data;
const llmTotalQueries = llmModelCount * (
  sasResultsAny._methodology.forced_choice_queries_per_model
  + sasResultsAny._methodology.open_ended_queries_per_model
);

// SAS main-section display uses the "Legal heavy" preset weights so it matches
// the SAS explorer's initial state. The canonical primary scheme (1:2:3:4 =
// [0.10, 0.20, 0.30, 0.40]) is still what the briefing and paper report and
// what you get by clicking "Primary (1:2:3:4)" in the explorer.
const LEGAL_HEAVY_W = { D: 0.10, L: 0.50, I: 0.20, R: 0.20 };
function computeSas(r: any, w: typeof LEGAL_HEAVY_W): number | null {
  if (!r) return null;
  const tiers: ('D' | 'L' | 'I' | 'R')[] = ['D', 'L', 'I', 'R'];
  let total = 0, wsum = 0;
  for (const k of tiers) {
    const v = r[k];
    if (v != null) { total += w[k] * v; wsum += w[k]; }
  }
  return wsum > 0 ? total / wsum : null;
}
// Geodata propagation chain weekly downloads sum (npm + PyPI + CRAN + crates.io,
// excludes NuGet which only exposes lifetime totals).
const geoWeeklyMillions = '65.7';
const vars: Record<string, string> = {
  total: String(m.global.total_platforms),
  categories: String(m.global.total_categories),
  source_code: String(m.methodology.source_code),
  automated_api: String(m.methodology.automated_api),
  automated_data: String(m.methodology.automated_data),
  ip_ips: String(m.ip_geolocation.total_ips_tested),
  ip_asns: String(m.ip_geolocation.total_asns_tested),
  weather_total: String(m.weather.total),
  llm_models: String(llmModelCount),
  llm_queries: llmTotalQueries.toLocaleString(),
  geo_weekly_m: geoWeeklyMillions,
};
const fill = (s: string) => s.replace(/\{(\w+)\}/g, (_, k) => vars[k] ?? `{${k}}`);

// Override t with filled values for keys that have templates
const tFilled = new Proxy(t, {
  get(target, prop: string) {
    const val = (target as any)[prop];
    return typeof val === 'string' ? fill(val) : val;
  }
});
// Use tFilled for display, keep t for non-string access
const T = tFilled as typeof t;

const ukDetails = findingsUk as Record<string, string>;
const getDetail = (f: any) => lang === 'uk' ? (ukDetails[f.platform] || f.detail) : f.detail;

const findings = platformsData.findings || [];
const trends = (platformsData as any).trends || {};
const ipResults = (platformsData as any).ip_results || {};

// --- Global stats from manifest ---
const total = m.global.total_platforms;
const correct = m.global.by_status.correct || 0;
const incorrect = m.global.by_status.incorrect || 0;
const ambiguous = m.global.by_status.ambiguous || 0;
const blocked = m.global.by_status.blocked || 0;
const na = m.global.by_status['n/a'] || 0;

// Group findings by category (still needed for listings)
const categories = {} as Record<string, any[]>;
findings.forEach((f: any) => {
  if (!categories[f.category]) categories[f.category] = [];
  categories[f.category].push(f);
});

const categoryOrder = [
  'data_visualization', 'open_source', 'map_service', 'tech_infrastructure',
  'weather', 'reference', 'travel', 'ip_geolocation',
  'search_engine', 'telecom'
];

const statusOrder = { correct: 0, incorrect: 1, ambiguous: 2, blocked: 3, 'n/a': 4 } as Record<string, number>;
const sortByStatus = (a: any, b: any) => (statusOrder[a.status] ?? 5) - (statusOrder[b.status] ?? 5);
const categoryLabels = t.categories;

// --- Chart percentages from manifest ---
const pCorrect = Math.round(correct / total * 100);
const pIncorrect = Math.round(incorrect / total * 100);
const pAmbiguous = Math.round(ambiguous / total * 100);
const pBlocked = Math.round(blocked / total * 100);
const pNA = Math.round(na / total * 100);

// Category bar chart — from manifest
const catStats = categoryOrder.filter(c => m.by_category[c]).map(c => ({
  name: (categoryLabels as any)[c] || c,
  total: m.by_category[c].total,
  correct: m.by_category[c].correct,
  incorrect: m.by_category[c].incorrect,
  ambiguous: m.by_category[c].ambiguous,
}));

// --- Helper: get category findings + stats from manifest ---
const catFindings = (cat: string) => findings.filter((f: any) => f.category === cat);
const cs = (cat: string) => m[cat] || m.by_category[cat] || { total: 0, correct: 0, incorrect: 0, ambiguous: 0, blocked: 0, 'n/a': 0 };
const pct = (n: number, t: number) => t > 0 ? Math.round(n / t * 100) : 0;

// --- Per-section data (findings + manifest stats) ---
// Weather — uses the fresh pipeline manifest (2026-04 re-verified scan)
const wpM = (weatherPipeline as any);
const wpSummary = wpM.summary;
const wpFindings = wpM.findings as any[];
const wpByStatus = (s: string) => wpFindings.filter(f => f.status === s);
const wCorrect = wpByStatus('correct');
const wUiAmbig = wpByStatus('url_correct_ui_ambiguous');
const wIncorrect = wpByStatus('incorrect');
const wUnreachable = wpByStatus('unreachable');
const wUntested = wpByStatus('untested');
const wNA = wpByStatus('na');
const wTotal = wpSummary.total_services;
const wPctCorrect = pct(wpSummary.correct, wTotal);
const wPctUiAmbig = pct(wpSummary.url_correct_ui_ambiguous, wTotal);
const wPctIncorrect = pct(wpSummary.incorrect, wTotal);
const wPctUnreachable = pct(wpSummary.unreachable, wTotal);
const wPctUntested = pct(wpSummary.untested, wTotal);
const wPctNA = pct(wpSummary.na, wTotal);
const wTzSimferopol = wpSummary.timezone_europe_simferopol;
const wTzMoscow = wpSummary.timezone_europe_moscow;
const wGeonamesCC = wpSummary.geonames_country_code;
const wAccuWeather = wpFindings.find((f: any) => f.platform === 'AccuWeather');
const wWeatherCom = wpFindings.find((f: any) => f.platform?.startsWith('Weather.com'));

// Institutions — uses the fresh pipeline manifest (2026-04 consolidated scan)
const instM = (institutionsPipeline as any);
const instSummary = instM.summary;
const instFindings = (instM.findings || []) as any[];
const instByStatus = (s: string) => instFindings.filter(f => f.status === s);
const instCorrect = instByStatus('correct');
const instAmbiguous = instByStatus('ambiguous');
const instIncorrect = instByStatus('incorrect');
const instByCategory = (cat: string) => instFindings.filter(f => f.category === cat);
const instLegislation = instByCategory('legislation_sanctions');
const instLoC = instByCategory('library_of_congress');
const instResearch = instByCategory('research_registry');
const instOfacUA = instSummary.ofac_crimea_pob_ukraine;
const instOfacRU = instSummary.ofac_crimea_pob_russia;
const instRorTotal = instSummary.ror_institutions_total;
const instRorUA = instSummary.ror_institutions_ua;
const instRorRU = instSummary.ror_institutions_ru;

// ── Geodata pipeline + 3D propagation graph data ──────────────
const geoM = (geodataPipeline as any);
const geoSummary = geoM.summary;
const geoFindings = (geoM.findings || []) as any[];
const geoCrimeaRU = geoSummary.natural_earth_crimea_russia_fields;
const geoCrimeaUA = geoSummary.natural_earth_crimea_ukraine_fields;
const geoSevRU = geoSummary.natural_earth_sevastopol_russia_fields;
const geoSevUA = geoSummary.natural_earth_sevastopol_ukraine_fields;
const geoNeSovereignt = geoSummary.natural_earth_admin_0_sovereignt;
const geoOpenIssues = geoSummary.github_open_crimea_issues;
const geoTotalIssues = geoSummary.github_total_crimea_items;
const geoNpmTotal = geoSummary.npm_total_weekly_downloads;
const geoPypiTotal = geoSummary.pypi_total_weekly_downloads;
const geoPypiHigh = geoSummary.pypi_high_level_total;
const geoPypiBindings = geoSummary.pypi_cpp_bindings_total;
const geoCranTotal = geoSummary.cran_total_weekly_downloads;
const geoCratesTotal = geoSummary.crates_total_weekly_downloads;
const geoNugetCumulative = geoSummary.nuget_lifetime_downloads_total;
const geoCrossEcoTotal = geoSummary.cross_ecosystem_total_weekly_downloads;

// Propagation chain is now a static HTML layered diagram in the geodata section;
// the old buildPropagationGraph helper + d3-sankey lazy loader have been removed.

// ── Grounding pipeline — single source of truth from grounding.json ──
const grM = (groundingData as any);
const grTotal = grM.total_citations;
const grSanc = grM.results.sanctioned;
const grGov = grM.results.government;
const grRu = grM.results.russian_other;
const grIntl = grM.results.international;
const grRuTotal = grM.results.russian_total;
const grModels = grM.by_model;
const grProxy = grM.proxy_probes;
const fmt = (n: number) => n.toLocaleString();

// ── Corpora pipeline — single source of truth from corpora.json ──
const corpM = (corporaData as any);
const corpDocs = corpM.summary.documents_scanned;
const corpRuFraming = corpM.summary.russia_framing;
const corpStateMedia = corpM.summary.state_media;
const corpDois = corpM.summary.russia_framing_dois;
const corpQuoted = corpM.summary.quoted_examples;
const corpDocsLabel = (corpDocs / 1e6).toFixed(1) + 'M';
const corpRuLabel = (corpRuFraming / 1e3).toFixed(0) + 'K';
const corpMediaLabel = (corpStateMedia / 1e3).toFixed(0) + 'K';


// ── Pipeline manifests for the rewired sections ───────────────
const tcMani = (telecomPipeline as any);
const tcSum = tcMani.summary;
const tcFreshFindings = (tcMani.findings || []) as any[];
const tcReassigned = tcSum.asns_reassigned;
const tcStillOriginal = tcSum.asns_still_at_original_holder;
const tcAsnsProbed = tcSum.asns_probed;
const tcRipeRU = tcSum.asns_ripe_country_ru;
const tcRipeUA = tcSum.asns_ripe_country_ua;

const ipMani = (ipPipeline as any);
const ipSum = ipMani.summary;
const ipFreshFindings = (ipMani.findings || []) as any[];
const ipPctUaFresh = ipSum.pct_ua;
const ipPctRuFresh = ipSum.pct_ru;
const ipPctOtherFresh = ipSum.pct_other;
const ipAsnConsensusUaFresh = ipSum.asn_consensus_ua;
const ipAsnConsensusRuFresh = ipSum.asn_consensus_ru;
const ipTotalLookupsFresh = ipSum.total_lookups;
const ipTotalIpsFresh = ipSum.total_ips_sampled;
const ipTotalAsnsFresh = ipSum.total_asns_tested;

const mediaMani = (mediaPipeline as any);
const mediaSum = mediaMani.summary;
const mediaTotal = mediaSum.total_articles;
const mediaClassified = mediaSum.classified_any_signal;
const mediaLlmVerified = mediaSum.llm_verified;
const mediaEndorseAll = mediaSum.llm_endorses_all;
const mediaEndorseNonRu = mediaSum.llm_endorses_nonrussian_domain;
const mediaPrecisionAll = mediaSum.precision_stage1_overall;
const mediaPrecisionNonRu = mediaSum.precision_stage1_nonrussian;
const mediaMajorIntlEndorse = mediaSum.major_international_outlets_endorsements;
const mediaPrecisionAllCi = mediaSum.precision_stage1_overall_ci95_pct;
const mediaPrecisionNonRuCi = mediaSum.precision_stage1_nonrussian_ci95_pct;
const mediaRule3 = mediaSum.major_intl_zero_endorsements_rule_of_3_upper_pct;

const techMani = (techInfraPipeline as any);
const techSum = techMani.summary;
const techFindings = (techMani.findings || []) as any[];
const techIanaCC = techSum.iana_zone1970_cc;
const techIanaLegacy = techSum.iana_zone_tab_cc;
const techLpnRu = techSum.libphonenumber_ru_crimean_entries;
const techLpnUa = techSum.libphonenumber_ua_crimean_entries;
const techLpn7978 = techSum.libphonenumber_7978_carriers;
const techOsmUa = techSum.osm_ua_count;
const techOsmTotal = techSum.osm_cities_tested;

// Map services
const mapFindings = catFindings('map_service');
const mS = cs('map_service');
const mCorrect = mapFindings.filter((f: any) => f.status === 'correct');
const mIncorrect = mapFindings.filter((f: any) => f.status === 'incorrect');
const mAmbiguous = mapFindings.filter((f: any) => f.status === 'ambiguous');
const mTotal = mS.total;
const mPctCorrect = pct(mS.correct, mTotal);
const mPctIncorrect = pct(mS.incorrect, mTotal);
const mPctAmbiguous = pct(mS.ambiguous, mTotal);

// IP Geolocation
const ipM = m.ip_geolocation;
const ipTotalLookups = ipM.total_lookups;
const ipTotalIPs = ipM.total_ips_tested;
const ipTotalASNs = ipM.total_asns_tested;
const ipByCountry = ipM.by_country;
const ipByProvider = ipResults.by_provider || {};
const ipByASN = ipResults.by_asn || {};
const ipPctUA = ipM.pct_ua;
const ipPctRU = ipM.pct_ru;
const ipPctOther = ipM.pct_other;
const asnEntries = Object.entries(ipByASN).map(([id, info]: [string, any]) => ({ id, ...info }));
const asnSorted = asnEntries.sort((a: any, b: any) => {
  const order: Record<string, number> = { ukrainian: 0, mixed: 1, mixed_ru: 1, rerouted: 2 };
  return (order[a.origin] ?? 3) - (order[b.origin] ?? 3);
});

// Telecom
const telecomFindings = catFindings('telecom');
const tcS = cs('telecom');
const tcCorrect = telecomFindings.filter((f: any) => f.status === 'correct');
const tcIncorrect = telecomFindings.filter((f: any) => f.status === 'incorrect');
const tcBlocked = telecomFindings.filter((f: any) => f.status === 'blocked');
const tcNA = telecomFindings.filter((f: any) => f.status === 'n/a');

// Tech infrastructure
const infraFindings = catFindings('tech_infrastructure');
const iS = cs('tech_infrastructure');
const iCorrect = infraFindings.filter((f: any) => f.status === 'correct');
const iIncorrect = infraFindings.filter((f: any) => f.status === 'incorrect');
const iAmbiguous = infraFindings.filter((f: any) => f.status === 'ambiguous');
const iTotal = iS.total;
const iPctCorrect = pct(iS.correct, iTotal);
const iPctIncorrect = pct(iS.incorrect, iTotal);
const iPctAmbiguous = pct(iS.ambiguous, iTotal);

// Framing data
const fd = framingData as any;
const gdelt = fd.gdelt;
const academic = fd.academic;

// Media year-by-year for chart — 4 filter views
const byFilter = (fd.gdelt as any).by_year_by_filter || {};

function transformCorrected(data: any) {
  const out: any = {};
  for (const [y, d] of Object.entries(data as Record<string, any>)) {
    out[y] = { ukraine: d.ukraine || 0, russia: d.russia_corrected ?? d.russia ?? 0, disputed: d.disputed || 0 };
  }
  return out;
}

const mediaFilters: Record<string, any> = {
  international: transformCorrected(byFilter.international || {}),
  ukrainian: transformCorrected(byFilter.ukrainian || {}),
  russian: transformCorrected(byFilter.russian || {}),
  all: transformCorrected(byFilter.all || {}),
};

function computeTotals(data: any) {
  return Object.values(data as Record<string, any>).reduce(
    (acc: any, d: any) => ({ ukraine: acc.ukraine + (d.ukraine||0), russia: acc.russia + (d.russia||0), disputed: acc.disputed + (d.disputed||0) }),
    { ukraine: 0, russia: 0, disputed: 0 }
  );
}

const mediaTotals: Record<string, any> = {
  international: computeTotals(mediaFilters.international),
  ukrainian: computeTotals(mediaFilters.ukrainian),
  russian: computeTotals(mediaFilters.russian),
  all: computeTotals(mediaFilters.all),
};

const gdeltByYear = mediaFilters.international; // default
const mediaYears = Object.keys(mediaFilters.all).filter((y: string) => y >= '2015').sort();
const acadYears = Object.keys(academic.by_year).filter(y => y >= '2012').sort();

// Academic violators
const acadViolators = academic.violators || [];

// Media violators by filter (imported from media_violators.json)
const mediaViolatorsByFilter = mediaViolators as any;

---

<!-- Nav -->
<nav class="max-w-6xl mx-auto px-3 sm:px-6 py-3 sm:py-4 flex flex-wrap justify-between items-center gap-2">
  <div class="flex items-center gap-2 sm:gap-3">
    <!-- Crimean flag (1:6:1 ratio) -->
    <div class="w-8 h-5 rounded-sm overflow-hidden flex flex-col shrink-0">
      <div style="flex: 1" class="bg-[#0068B7]"></div>
      <div style="flex: 6" class="bg-white"></div>
      <div style="flex: 1" class="bg-[#D52B1E]"></div>
    </div>
    <span class="text-sm font-medium text-[#5c5f77] tracking-wide">{t.siteName}</span>
  </div>
  <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
    <!-- Crimea Platform -->
    <a href="https://crimea-platform.org/en/" target="_blank" class="text-xs text-[#6c6f85] hover:text-[#4c4f69] transition flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      <span class="hidden sm:inline">{t.navCrimeaPlatform}</span>
    </a>
    <!-- Datasets & Models -->
    <a href="https://huggingface.co/CrimeaIsUkraineOrg" target="_blank" class="text-xs text-[#6c6f85] hover:text-[#4c4f69] transition flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>
      <span class="hidden sm:inline">{t.navDatasets}</span>
    </a>
    <!-- GitHub -->
    <a href="https://github.com/IvanDobrovolsky/crimeaisukraine" target="_blank" class="text-xs text-[#6c6f85] hover:text-[#4c4f69] transition flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      <span class="hidden sm:inline">GitHub</span>
    </a>
    <!-- Language selector -->
    <div class="relative">
      <select
        id="lang-select"
        class="text-xs sm:text-sm font-medium text-[#4c4f69] bg-white border border-[#bcc0cc] px-2 sm:px-3 py-1 sm:py-1.5 pr-6 sm:pr-8 rounded cursor-pointer appearance-none transition hover:border-[#1e66f5] focus:outline-none focus:border-[#1e66f5]"
        style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 12 12%22%3E%3Cpath d=%22M3 5l3 3 3-3%22 stroke=%22%236c6f85%22 fill=%22none%22 stroke-width=%221.5%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 6px center;"
      >
        <option value="/" selected={lang === 'en'}>EN</option>
        <option value="/uk" selected={lang === 'uk'}>UA</option>
        <option value="/crh" selected={lang === 'crh'}>CRH</option>
        <option value="/de" selected={lang === 'de'}>DE</option>
        <option value="/es" selected={lang === 'es'}>ES</option>
        <option value="/fr" selected={lang === 'fr'}>FR</option>
        <option value="/ru" selected={lang === 'ru'}>RU</option>
      </select>
    </div>
    <script is:inline>
      document.getElementById('lang-select')?.addEventListener('change', function(e) {
        window.location.href = e.target.value || '/';
      });
    </script>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════════════════════
     Sticky sidebar navigation — anchors to every pipeline section
     Hidden on mobile (toggle button shows). Active section
     highlighted via IntersectionObserver.
     ═══════════════════════════════════════════════════════════════ -->
<aside id="side-nav" class="hidden xl:block fixed top-24 left-4 z-30 w-44 bg-[#e6e9ef]/90 border border-[#ccd0da] rounded-xl backdrop-blur-sm p-3">
  <div class="text-[10px] text-[#6c6f85] uppercase tracking-widest font-bold mb-2 px-2">{t.navSections}</div>
  <ul class="space-y-0.5 text-[11px]">
    {[
      { id: 'overview', label: t.navOverview },
      { id: 'geodata', label: t.navGeodata },
      { id: 'media-framing', label: t.navMediaFraming },
      { id: 'academic-framing', label: t.navAcademicFraming },
      { id: 'llm-audit', label: t.navLlmAudit },
      { id: 'grounding', label: t.navGrounding },
      { id: 'corpora', label: t.navCorpora },
      { id: 'wikipedia', label: t.navWikipedia },
      { id: 'map-services', label: t.navMapServices },
      { id: 'weather', label: t.navWeather },
      { id: 'ip-geolocation', label: t.navIpGeolocation },
