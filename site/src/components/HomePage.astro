          const pTotal = (results.UA || 0) + (results.RU || 0) + (results.other || 0);
          const pUA = pTotal > 0 ? Math.round((results.UA || 0) / pTotal * 100) : 0;
          const pRU = pTotal > 0 ? Math.round((results.RU || 0) / pTotal * 100) : 0;
          const pOther = pTotal > 0 ? Math.round((results.other || 0) / pTotal * 100) : 0;
          return (
            <div class="bg-[#0a0e1a] rounded-lg p-4 border border-[#1e293b]">
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-medium text-white">{provider}</span>
                <span class="text-xs text-[#64748b]">{pTotal} {lang === 'uk' ? 'запитів' : 'lookups'}</span>
              </div>
              <div class="flex h-4 rounded-full overflow-hidden bg-[#1e293b] mb-2">
                {pUA > 0 && <div class="bg-[#0057b7] h-full" style={`width: ${pUA}%`}></div>}
                {pRU > 0 && <div class="bg-[#ef4444] h-full" style={`width: ${pRU}%`}></div>}
                {pOther > 0 && <div class="bg-[#94a3b8] h-full" style={`width: ${pOther}%`}></div>}
              </div>
              <div class="flex gap-4 text-xs text-[#94a3b8]">
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#0057b7]"></span>UA {pUA}%</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>RU {pRU}%</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#94a3b8]"></span>{lang === 'uk' ? 'Інше' : 'Other'} {pOther}%</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Geolocation Providers tested -->
    <div class="mb-8">
      <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-3">
        {lang === 'uk' ? 'Протестовані сервіси геолокації' : 'Geolocation Services Tested'}
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2">
        {findings.filter((f: any) => f.category === 'ip_geolocation').sort((a: any, b: any) => (statusOrder[a.status] ?? 5) - (statusOrder[b.status] ?? 5)).map((f: any) => {
          const color = f.status === 'correct' ? '#22c55e' : f.status === 'incorrect' ? '#ef4444' : '#f59e0b';
          const icon = f.status === 'correct' ? '✓' : f.status === 'incorrect' ? '✗' : '⚠';
          return (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#1e293b]">
              <div class="flex items-center gap-2">
                <span class="flex-shrink-0 text-xs" style={`color: ${color}`}>{icon}</span>
                <span class="text-[#e2e8f0] truncate text-xs font-medium">{f.platform}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Insight callout -->
    <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#0057b7]/30">
      <p class="text-sm text-[#94a3b8]">
        <span class="text-[#0057b7] font-bold">{lang === 'uk' ? 'Висновок' : 'Key insight'}:</span> {t.ipInsight}
