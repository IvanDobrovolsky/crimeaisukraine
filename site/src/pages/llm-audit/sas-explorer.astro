---
// Interactive SAS (Sovereignty Alignment Score) weight explorer.
//
// Philosophy: no fixed weight scheme can ever escape the "why these weights?"
// critique. The only structurally correct answer is to hand the weights to
// the reader and let them see for themselves. This page does exactly that.
// Four sliders, one per tier. 33 models in the table. Live Spearman rho
// against the primary scheme. Share your weights in a URL hash.
//
// Data source: ../../data/llm_sas_results.json, regenerated by
// scripts/compute_sas.py on every run.

import Layout from '../../layouts/Layout.astro';
import sasResults from '../../data/llm_sas_results.json';
import modelsData from '../../data/llm_models.json';

const sasAny = sasResults as any;
const modelsAny = (modelsData as any).models;
const generatedAt = sasAny._generated || 'unknown';

// Shape the data for the client: one row per model with just the four tier
// means, plus lab / access / display name from the models registry.
const modelMap: Record<string, any> = {};
for (const m of modelsAny) modelMap[m.id] = m;

const rows = Object.entries(sasAny.results)
  .map(([id, r]: [string, any]) => {
    const meta = modelMap[id] || {};
    return {
      id,
      name: meta.display_name || id,
      org: meta.org || '',
      access: meta.access || meta.params || '',
      D: r.D,
      L: r.L,
      I: r.I,
      R: r.R,
      primarySas: r.sas,
      rlhfGap: r.rlhf_gap,
      n: r.n_languages,
    };
  })
  .filter((x) => x.D !== null && x.L !== null && x.I !== null)
  .sort((a, b) => (b.primarySas ?? 0) - (a.primarySas ?? 0));

const jsonPayload = JSON.stringify(rows);
---

<Layout title="SAS Explorer — Crimea Sovereignty Audit" lang="en">
  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-2"><a href="/#llm-audit" class="text-[#0057b7] hover:underline text-sm">← Back to LLM audit</a></div>

    <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">SAS weight explorer</h1>
    <p class="text-[#94a3b8] max-w-3xl mb-6">
      The <strong class="text-white">Sovereignty Alignment Score</strong> is a weighted composite of four tier means:
      direct territorial (D̄), legal-normative (L̄), implicit sovereignty (Ī), and free-recall (R̄). The formula is a
      dot product, <span class="font-mono text-[#e5e5e5]">SAS = <strong class="text-[#ffd700]">w</strong> · [D̄, L̄, Ī, R̄]</span>,
      where <strong class="text-white">w</strong> is the weight vector. Our primary report uses the pre-registered weight
      vector <span class="font-mono text-[#ffd700]"><strong>w</strong> = [0.10, 0.20, 0.30, 0.40]</span> — the smallest
      monotonic integer progression consistent with the theoretical ordering of RLHF patchability. But no fixed weight
      vector can ever escape the "why these weights?" critique. Move the sliders. Pick any <strong class="text-white">w</strong>
      you like. Watch the ranking update in real time. The page loads on the <strong class="text-white">Legal heavy</strong>
      preset so you can see the tool working immediately — click <em>Primary (1:2:3:4)</em> to snap back to the reported scheme.
    </p>

    <!-- Notation note -->
    <div class="bg-[#0a0e1a] border border-[#1e293b] rounded-xl p-3 mb-4 text-[11px] text-[#64748b]">
      <strong class="text-[#e5e5e5]">Notation:</strong> we follow the standard ML-paper convention — <strong class="text-[#e5e5e5]">bold lowercase</strong>
      for vectors (<strong class="text-[#e5e5e5]">w</strong>, <strong class="text-[#e5e5e5]">x</strong>), regular italic
      for scalar components (<span class="italic">w<sub>D</sub></span>, <span class="italic">D̄</span>), and square brackets
      <span class="font-mono">[·, ·, ·, ·]</span> for the components of a vector.
    </div>

    <!-- Methodology reminder -->
    <div class="bg-[#0a0e1a] border border-[#1e293b] rounded-xl p-4 mb-8 text-xs text-[#94a3b8]">
      Each tier mean is on [0, 1] where 1.0 = Ukraine-aligned, 0.5 = disputed/hedged, 0.0 = Russia-aligned.
      Each model was audited at <span class="font-mono text-[#e5e5e5]">temperature=0</span> with
      <span class="font-mono text-[#e5e5e5]">seed=42</span> on 1,850 forced-choice queries + 676 open-ended queries across 50 languages and 12 cities.
      D̄ / L̄ / Ī pool across all 50 forced-tier languages; R̄ pools across 13 free-recall languages.
      Source data: <a class="text-[#0057b7] hover:underline" href="https://github.com/IvanDobrovolsky/crimeaisukraine/blob/main/data/sas_scores.json">data/sas_scores.json</a>,
      regenerable via <span class="font-mono text-[#e5e5e5]">python3 scripts/compute_sas.py</span>.
      Generated <span class="font-mono">{generatedAt.slice(0, 16).replace('T', ' ')}</span>.
    </div>

    <!-- Sliders -->
    <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-6 mb-6">
      <div class="flex items-baseline justify-between mb-4 flex-wrap gap-3">
        <h2 class="text-lg font-bold text-white">Tier weights</h2>
        <div class="flex gap-2 flex-wrap">
          <button data-preset="primary" class="preset-btn text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#1e293b] text-[#94a3b8] hover:bg-[#334155] hover:text-white transition">Primary (1:2:3:4)</button>
          <button data-preset="uniform" class="preset-btn text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#1e293b] text-[#94a3b8] hover:bg-[#334155] hover:text-white transition">Uniform</button>
          <button data-preset="geometric" class="preset-btn text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#1e293b] text-[#94a3b8] hover:bg-[#334155] hover:text-white transition">Geometric 1:2:4:8</button>
          <button data-preset="free" class="preset-btn text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#1e293b] text-[#94a3b8] hover:bg-[#334155] hover:text-white transition">Free only</button>
          <button data-preset="forced" class="preset-btn text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#1e293b] text-[#94a3b8] hover:bg-[#334155] hover:text-white transition">Forced only</button>
          <button data-preset="legal" class="preset-btn text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#f97316] text-white font-semibold hover:bg-[#ea6511] transition">Legal heavy</button>
          <button id="copy-link-btn" class="text-[10px] uppercase tracking-wider px-3 py-1.5 rounded bg-[#ffd700]/20 text-[#ffd700] border border-[#ffd700]/40 hover:bg-[#ffd700]/30 transition">Copy my weights</button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
        <!-- D slider -->
        <div class="bg-[#0a0e1a] border border-[#1e293b] rounded-xl p-4">
          <div class="flex items-baseline justify-between mb-2">
            <div>
              <div class="text-xs font-mono text-[#e5e5e5]"><span class="italic">w<sub>D</sub></span> · direct territorial</div>
              <div class="text-[10px] text-[#64748b]">"Is Crimea Russian?"</div>
            </div>
            <div class="text-xl font-bold text-[#ef4444]" id="label-D">0.10</div>
          </div>
          <input type="range" id="slider-D" min="0" max="1" step="0.01" value="0.10"
                 class="w-full accent-[#ef4444]" />
          <div class="text-[10px] text-[#64748b] mt-1">easiest for RLHF to patch</div>
        </div>

        <!-- L slider -->
        <div class="bg-[#0a0e1a] border border-[#1e293b] rounded-xl p-4">
          <div class="flex items-baseline justify-between mb-2">
            <div>
              <div class="text-xs font-mono text-[#e5e5e5]"><span class="italic">w<sub>L</sub></span> · legal-normative</div>
              <div class="text-[10px] text-[#64748b]">"Did Russia annex illegally?"</div>
            </div>
            <div class="text-xl font-bold text-[#f97316]" id="label-L">0.50</div>
          </div>
          <input type="range" id="slider-L" min="0" max="1" step="0.01" value="0.50"
                 class="w-full accent-[#f97316]" />
          <div class="text-[10px] text-[#64748b] mt-1">needs specific legal signal</div>
        </div>

        <!-- I slider -->
        <div class="bg-[#0a0e1a] border border-[#1e293b] rounded-xl p-4">
          <div class="flex items-baseline justify-between mb-2">
            <div>
              <div class="text-xs font-mono text-[#e5e5e5]"><span class="italic">w<sub>I</sub></span> · implicit sovereignty</div>
              <div class="text-[10px] text-[#64748b]">"What country is Yalta in?"</div>
            </div>
            <div class="text-xl font-bold text-[#f59e0b]" id="label-I">0.20</div>
          </div>
          <input type="range" id="slider-I" min="0" max="1" step="0.01" value="0.20"
                 class="w-full accent-[#f59e0b]" />
          <div class="text-[10px] text-[#64748b] mt-1">indirect, harder to game</div>
        </div>

        <!-- R slider -->
        <div class="bg-[#0a0e1a] border border-[#ffd700]/30 rounded-xl p-4">
          <div class="flex items-baseline justify-between mb-2">
            <div>
              <div class="text-xs font-mono text-[#ffd700]"><span class="italic">w<sub>R</sub></span> · free-recall</div>
              <div class="text-[10px] text-[#64748b]">"Describe Crimea in a paragraph."</div>
            </div>
            <div class="text-xl font-bold text-[#ffd700]" id="label-R">0.20</div>
          </div>
          <input type="range" id="slider-R" min="0" max="1" step="0.01" value="0.20"
                 class="w-full accent-[#ffd700]" />
          <div class="text-[10px] text-[#64748b] mt-1">default generation — hardest to fix</div>
        </div>
      </div>

      <!-- Status line -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-[11px] pt-3 border-t border-[#1e293b]">
        <div>
          <div class="text-[10px] text-[#64748b] uppercase tracking-wider">Your normalised <strong class="text-[#e5e5e5]">w</strong></div>
          <div class="font-mono text-white mt-0.5" id="norm-weights">[0.10, 0.50, 0.20, 0.20]</div>
        </div>
        <div>
          <div class="text-[10px] text-[#64748b] uppercase tracking-wider">Raw slider sum</div>
          <div class="font-mono text-white mt-0.5"><span id="raw-sum">1.00</span></div>
        </div>
        <div>
          <div class="text-[10px] text-[#64748b] uppercase tracking-wider">Spearman ρ vs primary</div>
          <div class="font-mono text-[#84cc16] mt-0.5"><span id="spearman">—</span> · <span id="stability" class="text-[10px]">—</span></div>
        </div>
        <div>
          <div class="text-[10px] text-[#64748b] uppercase tracking-wider">Top-5 under your <strong class="text-[#e5e5e5]">w</strong></div>
          <div class="font-mono text-white mt-0.5 text-[10px] truncate" id="top5">—</div>
        </div>
      </div>
    </div>

    <!-- Live ranking -->
    <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-6 mb-6">
      <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
        <h2 class="text-lg font-bold text-white">Live SAS ranking</h2>
        <div class="text-[10px] text-[#64748b]">
          Updated on every slider move · <span id="model-count">{rows.length}</span> models
        </div>
      </div>
      <div id="ranking-container" class="space-y-1">
        <!-- bars rendered by JS -->
      </div>
    </div>

    <!-- Pareto scatter: D̄ vs R̄ -->
    <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-6 mb-8">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
        <h2 class="text-lg font-bold text-white">Weight-free view: forced-choice vs free-recall</h2>
        <div class="text-[10px] text-[#64748b]">static · independent of the sliders</div>
      </div>
      <p class="text-xs text-[#94a3b8] mb-4 max-w-3xl">
        Every model as a single point. The horizontal axis is D̄ (direct territorial mean — what standard forced-choice
        benchmarks measure). The vertical axis is R̄ (free-recall mean — what the model writes when asked to generate freely
        about a Crimean city). The dashed diagonal is <span class="font-mono">y = x</span>: the "consistent" line where
        surface answer matches default generation. <strong class="text-[#ef4444]">Below the diagonal</strong> = closed
        flagships hiding bias behind RLHF. <strong class="text-[#0057b7]">Above the diagonal</strong> = open / small models
        deploying cached Ukraine-aligned hedging templates in generation. The vertical distance from the diagonal is the
        RLHF gap. This view is deliberately weight-free — the structural asymmetry is visible without any choice of
        <strong class="text-white">w</strong>.
      </p>
      <div class="flex justify-center">
        <svg id="pareto-svg" viewBox="0 0 680 680" class="w-full max-w-[640px]" xmlns="http://www.w3.org/2000/svg">
          <!-- rendered by JS below -->
        </svg>
      </div>
      <p class="text-[10px] text-[#64748b] mt-2 text-center">Hover any point to see the model · click to open the detail page.</p>
    </div>

    <!-- Footer -->
    <div class="text-xs text-[#64748b]">
      <p class="mb-2">
        <strong class="text-[#e5e5e5]">What to look for.</strong>
        Drag the <em>w<sub>D</sub></em> slider all the way to 1 and the other three to 0: you are now ranking by forced-choice only (<strong class="text-[#e5e5e5]">w</strong> = [1, 0, 0, 0]). Notice that the closed flagships (Gemini 2.5 Pro, Claude Opus 4.6, GPT-5.4, Claude Sonnet 4.6) dominate. Now drag <em>w<sub>R</sub></em> all the way to 1 and the rest to 0: the ranking nearly <em>reverses</em>. Open and small models score higher on default generation because they never received the heavy RLHF surface patching the closed labs invested in. This is the RLHF-gap story in one gesture. The Spearman ρ between those two extremes is <strong class="text-[#ef4444]">−0.486</strong> — a ranking inversion in the weight space.
      </p>
      <p class="mb-2">
        <strong class="text-[#e5e5e5]">What the primary (1:2:3:4) scheme does.</strong>
        It interpolates between those extremes, giving each tier one more unit of weight than the previous in inverse proportion to how easily fine-tuning can patch that tier: <strong class="text-[#e5e5e5]">w</strong> = [0.10, 0.20, 0.30, 0.40]. Any monotonic scheme (uniform, geometric 1:2:4:8, our 1:2:3:4) ranks the top 5 models almost identically. The Spearman ρ across these three schemes is above 0.98.
      </p>
      <p>
        <strong class="text-[#e5e5e5]">Try to break the top 5.</strong> We could not find any sane weight scheme in which Gemini 2.5 Pro, Claude Opus 4.6, or GPT-5.4 drops out of the top 5. If you find one, <a href="https://github.com/IvanDobrovolsky/crimeaisukraine/issues/new" class="text-[#0057b7] hover:underline">open an issue</a> with the URL of your weight configuration (the URL hash encodes the slider state) and we will add it to the known-counterexamples list.
      </p>
    </div>
  </main>

  <script is:inline set:html={`window.__SAS_ROWS__ = ${jsonPayload};`}></script>

  <script is:inline>
    (function () {
      const rows = window.__SAS_ROWS__;
      const container = document.getElementById('ranking-container');
      const sliderD = document.getElementById('slider-D');
      const sliderL = document.getElementById('slider-L');
      const sliderI = document.getElementById('slider-I');
      const sliderR = document.getElementById('slider-R');
      const labelD = document.getElementById('label-D');
      const labelL = document.getElementById('label-L');
      const labelI = document.getElementById('label-I');
      const labelR = document.getElementById('label-R');
      const normEl = document.getElementById('norm-weights');
      const rawSumEl = document.getElementById('raw-sum');
      const spearmanEl = document.getElementById('spearman');
      const stabilityEl = document.getElementById('stability');
      const top5El = document.getElementById('top5');

      // Pre-compute the primary-scheme ranking for Spearman comparison.
      const PRIMARY_W = { D: 0.10, L: 0.20, I: 0.30, R: 0.40 };
      function sasOf(row, w) {
        let total = 0, wsum = 0;
        for (const t of ['D', 'L', 'I', 'R']) {
          if (row[t] != null) { total += w[t] * row[t]; wsum += w[t]; }
        }
        return wsum > 0 ? total / wsum : 0;
      }
      // Primary SAS (matches the server-computed "primarySas" field) — we
      // use the stored primarySas so we do not drift from the audit.
      const primaryScored = rows
        .map((r, i) => ({ i, sas: r.primarySas ?? sasOf(r, PRIMARY_W) }))
        .sort((a, b) => b.sas - a.sas);
      const primaryRank = new Array(rows.length);
      primaryScored.forEach((x, rank) => { primaryRank[x.i] = rank + 1; });

      function spearman(ranksA, ranksB) {
        const n = ranksA.length;
        if (n < 2) return 1;
        let d2 = 0;
        for (let i = 0; i < n; i++) {
          const d = ranksA[i] - ranksB[i];
          d2 += d * d;
        }
        return 1 - (6 * d2) / (n * (n * n - 1));
      }

      const PRESETS = {
        primary:   { D: 0.10, L: 0.20, I: 0.30, R: 0.40 },
        uniform:   { D: 0.25, L: 0.25, I: 0.25, R: 0.25 },
        geometric: { D: 1/15, L: 2/15, I: 4/15, R: 8/15 },
        free:      { D: 0.00, L: 0.00, I: 0.00, R: 1.00 },
        forced:    { D: 0.30, L: 0.30, I: 0.40, R: 0.00 },
        legal:     { D: 0.10, L: 0.50, I: 0.20, R: 0.20 },
      };

      // Build static DOM for each model once, then only update values on slider change.
      const rowNodes = rows.map((r, i) => {
        const row = document.createElement('div');
        row.className = 'sas-row grid grid-cols-[2rem_1fr_3rem_auto] md:grid-cols-[2rem_minmax(10rem,16rem)_1fr_3.5rem_4.5rem] gap-2 items-center py-1 px-2 rounded hover:bg-[#0a0e1a]/60 transition';
        row.dataset.idx = i;

        const rank = document.createElement('div');
        rank.className = 'text-[10px] text-[#64748b] font-mono';
        rank.textContent = '—';

        const nameWrap = document.createElement('div');
        nameWrap.className = 'flex items-center gap-2 min-w-0';
        const nameEl = document.createElement('a');
        nameEl.href = '/llm-audit/' + r.id;
        nameEl.className = 'text-xs md:text-sm text-[#0057b7] hover:underline truncate font-medium';
        nameEl.textContent = r.name;
        const orgEl = document.createElement('span');
        orgEl.className = 'text-[10px] text-[#64748b] hidden md:inline';
        orgEl.textContent = r.org;
        nameWrap.appendChild(nameEl);
        nameWrap.appendChild(orgEl);

        const barWrap = document.createElement('div');
        barWrap.className = 'h-5 bg-[#0a0e1a] border border-[#1e293b] rounded overflow-hidden relative';
        const bar = document.createElement('div');
        bar.className = 'h-full transition-all duration-75';
        bar.style.width = '0%';
        barWrap.appendChild(bar);

        const sasEl = document.createElement('div');
        sasEl.className = 'text-[11px] md:text-xs font-mono font-bold text-white text-right';
        sasEl.textContent = '—';

        const gapEl = document.createElement('div');
        gapEl.className = 'text-[10px] font-mono text-right hidden md:block';
        const g = r.rlhfGap;
        if (g == null) {
          gapEl.textContent = '—';
          gapEl.style.color = '#64748b';
        } else {
          gapEl.textContent = (g >= 0 ? '+' : '') + g.toFixed(2);
          gapEl.style.color = g >= 0.15 ? '#ef4444' : g >= 0.05 ? '#f59e0b' : g > -0.05 ? '#94a3b8' : g > -0.20 ? '#84cc16' : '#22c55e';
        }

        row.appendChild(rank);
        row.appendChild(nameWrap);
        row.appendChild(barWrap);
        row.appendChild(sasEl);
        row.appendChild(gapEl);
        return { row, rank, bar, sasEl };
      });

      rowNodes.forEach(({ row }) => container.appendChild(row));

      let rafId = null;
      function render() {
        rafId = null;
        const wRaw = {
          D: parseFloat(sliderD.value),
          L: parseFloat(sliderL.value),
          I: parseFloat(sliderI.value),
          R: parseFloat(sliderR.value),
        };
        const sum = wRaw.D + wRaw.L + wRaw.I + wRaw.R;
        rawSumEl.textContent = sum.toFixed(2);
        labelD.textContent = wRaw.D.toFixed(2);
        labelL.textContent = wRaw.L.toFixed(2);
        labelI.textContent = wRaw.I.toFixed(2);
        labelR.textContent = wRaw.R.toFixed(2);

        let w;
        if (sum < 0.01) {
          // degenerate: fall back to uniform so we do not divide by zero
          w = { D: 0.25, L: 0.25, I: 0.25, R: 0.25 };
          normEl.textContent = '[0.25, 0.25, 0.25, 0.25] (sum=0 fallback)';
        } else {
          w = {
            D: wRaw.D / sum,
            L: wRaw.L / sum,
            I: wRaw.I / sum,
            R: wRaw.R / sum,
          };
          normEl.textContent = '[' + [w.D, w.L, w.I, w.R].map(x => x.toFixed(2)).join(', ') + ']';
        }

        // Score every model under current weights.
        const scored = rows.map((r, i) => ({ i, sas: sasOf(r, w) }));
        scored.sort((a, b) => b.sas - a.sas);

        // Compute user-rank-by-index so we can Spearman against primary.
        const userRank = new Array(rows.length);
        scored.forEach((x, rank) => { userRank[x.i] = rank + 1; });
        const rho = spearman(userRank, primaryRank);
        spearmanEl.textContent = rho.toFixed(3);
        if (rho >= 0.95) {
          spearmanEl.style.color = '#22c55e';
          stabilityEl.textContent = 'stable';
        } else if (rho >= 0.80) {
          spearmanEl.style.color = '#84cc16';
          stabilityEl.textContent = 'stable';
        } else if (rho >= 0.50) {
          spearmanEl.style.color = '#f59e0b';
          stabilityEl.textContent = 'moderate';
        } else if (rho >= 0) {
          spearmanEl.style.color = '#f97316';
          stabilityEl.textContent = 'weak';
        } else {
          spearmanEl.style.color = '#ef4444';
          stabilityEl.textContent = 'inverted!';
        }

        // Top 5
        top5El.textContent = scored.slice(0, 5).map(s => rows[s.i].name.split(' ')[0]).join(' · ');

        // Rearrange DOM to match new order, and update values.
        for (let rank = 0; rank < scored.length; rank++) {
          const { i, sas } = scored[rank];
          const node = rowNodes[i];
          if (container.children[rank] !== node.row) {
            container.insertBefore(node.row, container.children[rank] || null);
          }
          node.rank.textContent = (rank + 1).toString();
          node.sasEl.textContent = sas.toFixed(3);
          const pct = Math.max(0, Math.min(100, sas * 100));
          node.bar.style.width = pct + '%';
          const color = sas >= 0.85 ? '#22c55e' : sas >= 0.75 ? '#84cc16' : sas >= 0.65 ? '#f59e0b' : sas >= 0.55 ? '#f97316' : '#ef4444';
          node.bar.style.backgroundColor = color;
        }

        // Update preset highlighting
        highlightMatchingPreset();

        // Encode state into URL hash for sharing.
        const hash = 'w=' + wRaw.D.toFixed(2) + ',' + wRaw.L.toFixed(2) + ',' + wRaw.I.toFixed(2) + ',' + wRaw.R.toFixed(2);
        if (history.replaceState) {
          history.replaceState(null, '', '#' + hash);
        } else {
          location.hash = hash;
        }
      }

      // ── Pareto scatter: static, rendered once ──────────────────────
      function renderPareto() {
        const svg = document.getElementById('pareto-svg');
        if (!svg) return;
        const W = 680, H = 680;
        const margin = { top: 30, right: 30, bottom: 60, left: 60 };
        const plotW = W - margin.left - margin.right;
        const plotH = H - margin.top - margin.bottom;
        const xScale = (v) => margin.left + v * plotW;
        const yScale = (v) => margin.top + (1 - v) * plotH;

        const SVG_NS = 'http://www.w3.org/2000/svg';
        const el = (tag, attrs, text) => {
          const e = document.createElementNS(SVG_NS, tag);
          for (const k in attrs) e.setAttribute(k, attrs[k]);
          if (text != null) e.textContent = text;
          return e;
        };

        // Background panels (below/above diagonal)
        const belowPts = [
          [margin.left, margin.top + plotH],
          [margin.left + plotW, margin.top],
          [margin.left + plotW, margin.top + plotH],
        ].map(p => p.join(',')).join(' ');
        svg.appendChild(el('polygon', { points: belowPts, fill: '#ef4444', 'fill-opacity': 0.05 }));
        const abovePts = [
          [margin.left, margin.top + plotH],
          [margin.left, margin.top],
          [margin.left + plotW, margin.top],
        ].map(p => p.join(',')).join(' ');
        svg.appendChild(el('polygon', { points: abovePts, fill: '#0057b7', 'fill-opacity': 0.05 }));

        // Zone labels
        svg.appendChild(el('text', {
          x: xScale(0.78), y: yScale(0.30), fill: '#ef4444', 'font-size': 11,
          'font-weight': 'bold', 'text-anchor': 'middle', opacity: 0.85,
        }, 'surface-patched'));
        svg.appendChild(el('text', {
          x: xScale(0.78), y: yScale(0.24), fill: '#ef4444', 'font-size': 9,
          'text-anchor': 'middle', opacity: 0.75,
        }, '(forced > free)'));
        svg.appendChild(el('text', {
          x: xScale(0.25), y: yScale(0.80), fill: '#0057b7', 'font-size': 11,
          'font-weight': 'bold', 'text-anchor': 'middle', opacity: 0.85,
        }, 'cached hedging'));
        svg.appendChild(el('text', {
          x: xScale(0.25), y: yScale(0.74), fill: '#0057b7', 'font-size': 9,
          'text-anchor': 'middle', opacity: 0.75,
        }, '(free > forced)'));

        // Grid lines every 0.1
        for (let v = 0; v <= 1.001; v += 0.1) {
          svg.appendChild(el('line', {
            x1: xScale(v), y1: margin.top, x2: xScale(v), y2: margin.top + plotH,
            stroke: '#1e293b', 'stroke-width': 0.6, 'stroke-dasharray': '2 3',
          }));
          svg.appendChild(el('line', {
            x1: margin.left, y1: yScale(v), x2: margin.left + plotW, y2: yScale(v),
            stroke: '#1e293b', 'stroke-width': 0.6, 'stroke-dasharray': '2 3',
          }));
        }

        // Diagonal y=x
        svg.appendChild(el('line', {
          x1: xScale(0), y1: yScale(0), x2: xScale(1), y2: yScale(1),
          stroke: '#64748b', 'stroke-width': 1.5, 'stroke-dasharray': '6 4',
        }));
        svg.appendChild(el('text', {
          x: xScale(0.92), y: yScale(0.89), fill: '#64748b', 'font-size': 10,
          'font-style': 'italic', 'text-anchor': 'end',
        }, 'y = x  (consistent)'));

        // Axes
        svg.appendChild(el('line', {
          x1: margin.left, y1: margin.top + plotH,
          x2: margin.left + plotW, y2: margin.top + plotH,
          stroke: '#475569', 'stroke-width': 1.5,
        }));
        svg.appendChild(el('line', {
          x1: margin.left, y1: margin.top, x2: margin.left, y2: margin.top + plotH,
          stroke: '#475569', 'stroke-width': 1.5,
        }));

        // Axis labels
        for (let v = 0; v <= 1.001; v += 0.2) {
          svg.appendChild(el('text', {
            x: xScale(v), y: margin.top + plotH + 16, fill: '#94a3b8', 'font-size': 10,
            'text-anchor': 'middle',
          }, v.toFixed(1)));
          svg.appendChild(el('text', {
            x: margin.left - 8, y: yScale(v) + 4, fill: '#94a3b8', 'font-size': 10,
            'text-anchor': 'end',
          }, v.toFixed(1)));
        }
        svg.appendChild(el('text', {
          x: margin.left + plotW / 2, y: margin.top + plotH + 38,
          fill: '#e5e5e5', 'font-size': 12, 'text-anchor': 'middle', 'font-weight': 'bold',
        }, 'D̄ — direct territorial (forced-choice)'));
        const yLabel = el('text', {
          x: 18, y: margin.top + plotH / 2,
          fill: '#e5e5e5', 'font-size': 12, 'text-anchor': 'middle', 'font-weight': 'bold',
          transform: 'rotate(-90, 18, ' + (margin.top + plotH / 2) + ')',
        }, 'R̄ — free-recall (default generation)');
        svg.appendChild(yLabel);

        // Points — handle label collisions by nudging
        const placed = [];
        rows.forEach((r, idx) => {
          if (r.D == null || r.R == null) return;
          const cx = xScale(r.D);
          const cy = yScale(r.R);
          const isClosed = /closed/i.test(r.access);
          const g = r.rlhfGap ?? 0;
          const color = g > 0.10 ? '#ef4444' : g < -0.10 ? '#0057b7' : '#f59e0b';

          // Interactive group: link + hover
          const a = el('a', { href: '/llm-audit/' + r.id });
          const circle = el(isClosed ? 'circle' : 'rect',
            isClosed
              ? { cx: cx, cy: cy, r: 9, fill: color, stroke: 'white', 'stroke-width': 1.5, opacity: 0.92, 'data-idx': idx }
              : { x: cx - 9, y: cy - 9, width: 18, height: 18, fill: color, stroke: 'white', 'stroke-width': 1.5, opacity: 0.92, 'data-idx': idx });
          circle.style.cursor = 'pointer';
          const title = el('title', {}, r.name + ' — D̄=' + r.D.toFixed(3) + '  R̄=' + r.R.toFixed(3) + '  gap=' + (g >= 0 ? '+' : '') + g.toFixed(3));
          circle.appendChild(title);
          a.appendChild(circle);
          svg.appendChild(a);

          // Label collision: try 8 placements around the point, pick first non-overlapping
          const shortName = r.name.replace('Claude ', '').replace('GPT-', 'gpt-')
              .replace('Gemini ', 'gem-').replace('-4.6', '').replace('-2.5', '')
              .replace('Llama ', 'llama').replace('Qwen ', 'qwen')
              .replace('Gemma ', 'gemma').replace('Mistral ', 'mistral');
          const placements = [
            { dx: 12, dy: 4, anchor: 'start' },
            { dx: -12, dy: 4, anchor: 'end' },
            { dx: 0, dy: -12, anchor: 'middle' },
            { dx: 0, dy: 18, anchor: 'middle' },
            { dx: 12, dy: -8, anchor: 'start' },
            { dx: -12, dy: -8, anchor: 'end' },
            { dx: 12, dy: 16, anchor: 'start' },
            { dx: -12, dy: 16, anchor: 'end' },
          ];
          let chosen = placements[0];
          for (const p of placements) {
            const lx = cx + p.dx;
            const ly = cy + p.dy;
            const collides = placed.some(pl => Math.abs(pl.x - lx) < 55 && Math.abs(pl.y - ly) < 11);
            if (!collides) { chosen = p; break; }
          }
          const lx = cx + chosen.dx;
          const ly = cy + chosen.dy;
          placed.push({ x: lx, y: ly });

          svg.appendChild(el('text', {
            x: lx, y: ly, fill: '#e5e5e5', 'font-size': 10,
            'text-anchor': chosen.anchor, 'font-weight': '600',
            'pointer-events': 'none',
          }, shortName));
        });

        // Legend
        const legendX = margin.left + plotW - 190;
        const legendY = margin.top + plotH - 82;
        svg.appendChild(el('rect', {
          x: legendX - 8, y: legendY - 14, width: 198, height: 74,
          fill: '#0a0e1a', stroke: '#1e293b', 'stroke-width': 1, rx: 4,
        }));
        const li = (offset, shape, color, text) => {
          const sy = legendY + offset;
          if (shape === 'circle') {
            svg.appendChild(el('circle', { cx: legendX + 6, cy: sy - 3, r: 6, fill: color, stroke: 'white', 'stroke-width': 1 }));
          } else {
            svg.appendChild(el('rect', { x: legendX, y: sy - 9, width: 12, height: 12, fill: color, stroke: 'white', 'stroke-width': 1 }));
          }
          svg.appendChild(el('text', { x: legendX + 18, y: sy, fill: '#94a3b8', 'font-size': 9 }, text));
        };
        li(0, 'circle', '#ef4444', 'closed · pos. RLHF gap');
        li(15, 'rect',   '#0057b7', 'open · neg. RLHF gap');
        li(30, 'circle', '#f59e0b', 'near-zero gap');
        li(45, 'line',   '#64748b', '');
        svg.appendChild(el('line', {
          x1: legendX, y1: legendY + 42, x2: legendX + 12, y2: legendY + 42,
          stroke: '#64748b', 'stroke-width': 1.5, 'stroke-dasharray': '4 3',
        }));
        svg.appendChild(el('text', {
          x: legendX + 18, y: legendY + 45, fill: '#94a3b8', 'font-size': 9,
        }, 'diagonal y = x'));
      }
      renderPareto();

      function requestRender() {
        if (rafId != null) return;
        rafId = requestAnimationFrame(render);
      }

      [sliderD, sliderL, sliderI, sliderR].forEach(s => {
        s.addEventListener('input', requestRender);
      });

      // Preset button highlighting — track which preset (if any) the
      // current slider state matches and style the buttons accordingly.
      const presetBtns = document.querySelectorAll('.preset-btn');
      function highlightMatchingPreset() {
        const cur = {
          D: parseFloat(sliderD.value),
          L: parseFloat(sliderL.value),
          I: parseFloat(sliderI.value),
          R: parseFloat(sliderR.value),
        };
        let matched = null;
        for (const [name, w] of Object.entries(PRESETS)) {
          const d = Math.abs(w.D - cur.D) + Math.abs(w.L - cur.L) +
                    Math.abs(w.I - cur.I) + Math.abs(w.R - cur.R);
          if (d < 0.015) { matched = name; break; }
        }
        presetBtns.forEach(b => {
          const isActive = b.dataset.preset === matched;
          if (isActive) {
            b.classList.remove('bg-[#1e293b]', 'text-[#94a3b8]', 'hover:bg-[#334155]');
            b.classList.add('bg-[#0057b7]', 'text-white', 'font-semibold');
          } else {
            b.classList.remove('bg-[#0057b7]', 'bg-[#f97316]', 'text-white', 'font-semibold');
            b.classList.add('bg-[#1e293b]', 'text-[#94a3b8]', 'hover:bg-[#334155]');
          }
        });
      }

      // Presets
      presetBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const p = btn.dataset.preset;
          const w = PRESETS[p];
          if (!w) return;
          sliderD.value = w.D;
          sliderL.value = w.L;
          sliderI.value = w.I;
          sliderR.value = w.R;
          requestRender();
        });
      });

      // Copy share link
      document.getElementById('copy-link-btn').addEventListener('click', (e) => {
        navigator.clipboard.writeText(location.href).then(() => {
          const btn = e.target;
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 1500);
        });
      });

      // Restore from URL hash if present
      const hashMatch = location.hash.match(/w=([\\d\\.]+),([\\d\\.]+),([\\d\\.]+),([\\d\\.]+)/);
      if (hashMatch) {
        sliderD.value = hashMatch[1];
        sliderL.value = hashMatch[2];
        sliderI.value = hashMatch[3];
        sliderR.value = hashMatch[4];
      }

      render();
    })();
  </script>
</Layout>
