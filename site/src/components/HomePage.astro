<script>
  // Highlight the currently-visible section in the sidebar
  (function () {
    const links = document.querySelectorAll('[data-side-nav]') as NodeListOf<HTMLAnchorElement>;
    if (!links.length) return;
    const map = new Map<string, HTMLAnchorElement>();
    links.forEach(l => map.set(l.dataset.sideNav || '', l));

    const setActive = (id: string) => {
      links.forEach(l => l.classList.remove('bg-[#ccd0da]', 'text-[#4c4f69]'));
      const link = map.get(id);
      if (link) link.classList.add('bg-[#ccd0da]', 'text-[#4c4f69]');
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter(e => e.isIntersecting)
          .sort((a, b) => (a.target.getBoundingClientRect().top || 0) - (b.target.getBoundingClientRect().top || 0));
        if (visible.length) {
          const id = (visible[0].target as HTMLElement).id;
          if (id) setActive(id);
        }
      },
      { rootMargin: '-100px 0px -60% 0px', threshold: 0 }
    );
    map.forEach((_, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  })();
</script>

