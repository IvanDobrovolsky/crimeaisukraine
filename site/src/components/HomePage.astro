              <div class="flex gap-3 mt-1.5 text-[10px] text-[#64748b]">
                {asn.ua > 0 && <span>UA: {asn.ua}</span>}
                {asn.ru > 0 && <span>RU: {asn.ru}</span>}
                {asn.other > 0 && <span>{lang === 'uk' ? 'Інше' : 'Other'}: {asn.other}</span>}
