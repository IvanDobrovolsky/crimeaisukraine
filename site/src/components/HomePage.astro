      </div>
      <div class="bg-white border border-[#ccd0da] rounded-lg p-3">
        <div class="text-[10px] text-[#6c6f85] uppercase tracking-wider mb-1">{lang === 'uk' ? 'Інверсія малих моделей' : 'Open / small inversion'}</div>
        <div class="text-base text-[#4c4f69]"><strong>−0.08 to −0.49</strong> on 10 models. Smaller / open models leak hedging templates ("internationally recognized as Ukraine") in free-recall.</div>
      </div>
    </div>

    <!-- SAS table -->
    <div class="overflow-x-auto rounded-xl border border-[#ccd0da]">
      <table class="w-full text-xs md:text-sm">
        <thead>
          <tr class="bg-[#ccd0da]">
            <th class="p-2 text-left text-[#4c4f69] font-semibold">#</th>
            <th class="p-2 text-left text-[#4c4f69] font-semibold">Model</th>
            <th class="p-2 text-left text-[#4c4f69] font-semibold">Lab</th>
            <th class="p-2 text-left text-[#4c4f69] font-semibold">Access</th>
            <th class="p-2 text-center text-[#4c4f69] font-semibold">SAS</th>
            <th class="p-2 text-center text-[#4c4f69] font-semibold" title="Direct territorial mean">D̄</th>
            <th class="p-2 text-center text-[#4c4f69] font-semibold" title="Legal-normative mean">L̄</th>
            <th class="p-2 text-center text-[#4c4f69] font-semibold" title="Implicit sovereignty mean">Ī</th>
            <th class="p-2 text-center text-[#4c4f69] font-semibold" title="Free-recall mean">R̄</th>
            <th class="p-2 text-center text-[#4c4f69] font-semibold" title="RLHF gap = D̄ − R̄">RLHF gap</th>
          </tr>
        </thead>
        <tbody>
          {(modelsData as any).models
            .map((m: any) => {
              const r = (sasResults as any).results[m.id];
              return { m, r, sas: computeSas(r, LEGAL_HEAVY_W) };
            })
            .filter((row: any) => row.r && row.sas !== null)
            .sort((a: any, b: any) => (b.sas ?? 0) - (a.sas ?? 0))
            .map((row: any, idx: number) => {
              const m = row.m; const r = row.r;
              const sas = row.sas;
              const sasColor = sas >= 0.85 ? '#40a02b' : sas >= 0.75 ? '#40a02b' : sas >= 0.65 ? '#df8e1d' : sas >= 0.55 ? '#df8e1d' : '#d20f39';
              const cell = (v: number | null): string => {
                if (v === null) return '#ccd0da';
                if (v >= 0.85) return '#40a02b33';
                if (v >= 0.65) return '#df8e1d33';
                return '#d20f3933';
              };
              const gap = r.rlhf_gap;
              const gapColor = gap === null ? '#5c5f77' : gap >= 0.15 ? '#d20f39' : gap >= 0.05 ? '#df8e1d' : gap > -0.05 ? '#5c5f77' : gap > -0.20 ? '#40a02b' : '#40a02b';
              const f = (v: number | null) => v === null ? '—' : v.toFixed(3);
              const accessBadge = m.access === 'closed' ? 'closed' : 'open';
              const accessColor = m.access === 'closed' ? '#1e66f5' : '#40a02b';
              return (
                <tr class="border-t border-[#ccd0da] hover:bg-[#eff1f5]/50 transition">
                  <td class="p-2 text-[#6c6f85]">{idx + 1}</td>
                  <td class="p-2">
                    <a href={`/llm-audit/${m.id}`} class="text-[#1e66f5] hover:text-[#1e66f5] hover:underline font-medium">
                      {m.display_name}
                    </a>
                  </td>
                  <td class="p-2 text-[#5c5f77]">{m.org}</td>
                  <td class="p-2"><span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase" style={`background:${accessColor}33; color:${accessColor}`}>{accessBadge}</span></td>
                  <td class="p-2 text-center font-bold text-[#4c4f69]" style={`background:${sasColor}`}>{f(sas)}</td>
                  <td class="p-2 text-center text-[#4c4f69]" style={`background:${cell(r.D)}`}>{f(r.D)}</td>
                  <td class="p-2 text-center text-[#4c4f69]" style={`background:${cell(r.L)}`}>{f(r.L)}</td>
                  <td class="p-2 text-center text-[#4c4f69]" style={`background:${cell(r.I)}`}>{f(r.I)}</td>
                  <td class="p-2 text-center text-[#4c4f69]" style={`background:${cell(r.R)}`}>{f(r.R)}</td>
                  <td class="p-2 text-center font-bold" style={`color:${gapColor}`}>{gap === null ? '—' : (gap > 0 ? '+' : '') + gap.toFixed(3)}</td>
                </tr>
              );
            })}
        </tbody>
      </table>
    </div>

    <p class="text-xs text-[#6c6f85] mt-3">
      {lang === 'uk'
        ? <>Ранжування під первинною схемою <strong class="text-[#df8e1d]">Legal-heavy</strong> <strong class="text-[#4c4f69]">w</strong> = [0.10, 0.50, 0.20, 0.20]. Натисніть на назву моделі для детальної таблиці. Порівняйте з альтернативними схемами в <a href="/llm-audit/sas-explorer" class="text-[#1e66f5] hover:underline">інтерактивному дослідникові</a>: Spearman ρ &gt; 0.97 проти моноторної, рівномірної та геометричної схем. RLHF-розрив &gt; 0 = модель приховує дефолтний bias; розрив &lt; 0 = шаблон хеджування домінує.</>
        : <>Ranking under the primary <strong class="text-[#df8e1d]">Legal-heavy</strong> scheme <strong class="text-[#4c4f69]">w</strong> = [0.10, 0.50, 0.20, 0.20]. Click any model name for the detailed per-question table. Compare against alternative schemes in the <a href="/llm-audit/sas-explorer" class="text-[#1e66f5] hover:underline">interactive explorer</a>: Spearman ρ &gt; 0.97 against monotonic, uniform, and geometric schemes. A positive RLHF gap means the model hides its default bias; a negative gap means cached hedging templates in free generation dominate over the surface answer.</>}
    </p>
  </div>
</section>


