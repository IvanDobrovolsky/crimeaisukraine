---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = "91,670 academic papers scanned, 1,581 confirmed Russia-framing (98.3% human-verified). 18 frontier LLMs audited. Natural Earth propagates to 65M weekly downloads. The governance gap measured across maps, academic publishing, training corpora, and AI.",
  lang = 'en'
} = Astro.props;

const siteUrl = 'https://crimeaisukraine.org';
const ogImage = `${siteUrl}/og.png`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ivan Dobrovolskyi" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Crimea Is Ukraine — 91,670 papers scanned, 1,581 Russia-framing confirmed, 18 LLMs audited. Digital sovereignty research." />
    <meta property="og:locale" content={lang === 'uk' ? 'uk_UA' : 'en_US'} />
    <meta property="og:site_name" content="Crimea Is Ukraine" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Crimea Is Ukraine — automated digital sovereignty audit" />

    <!-- Canonical + Language alternates -->
    <link rel="canonical" href={lang === 'uk' ? `${siteUrl}/uk` : siteUrl} />
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="uk" href={`${siteUrl}/uk`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Source+Serif+4:opsz,wght@8..60,400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[#eff1f5] text-[#4c4f69]">
    <slot />
  </body>
</html>
