---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = "91,670 academic papers scanned, 1,581 confirmed Russia-framing (98.3% human-verified). 18 frontier LLMs audited. Natural Earth propagates to 65.7M weekly downloads. The governance gap measured across maps, academic publishing, training corpora, and AI.",
  lang = 'en'
} = Astro.props;

const siteUrl = 'https://crimeaisukraine.org';
const ogImage = `${siteUrl}/og.png`;

const langPaths: Record<string, string> = {
  en: '',
  uk: '/uk',
  es: '/es',
  de: '/de',
  fr: '/fr',
  ru: '/ru',
  crh: '/crh',
};

const ogLocales: Record<string, string> = {
  en: 'en_US',
  uk: 'uk_UA',
  es: 'es_ES',
  de: 'de_DE',
  fr: 'fr_FR',
  ru: 'ru_RU',
  crh: 'crh',
};

const canonicalUrl = lang === 'en' ? siteUrl : `${siteUrl}${langPaths[lang]}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ivan Dobrovolskyi" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Crimea Is Ukraine — 91,670 papers scanned, 1,581 Russia-framing confirmed, 18 LLMs audited." />
    <meta property="og:locale" content={ogLocales[lang] || 'en_US'} />
    <meta property="og:site_name" content="Crimea Is Ukraine" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Crimea Is Ukraine — digital sovereignty audit" />

    <!-- Canonical + Language alternates (all 7 languages) -->
    <link rel="canonical" href={canonicalUrl} />
    {Object.entries(langPaths).map(([l, path]) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${path}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Source+Serif+4:opsz,wght@8..60,400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[#eff1f5] text-[#4c4f69]">
    <slot />
  </body>
</html>
