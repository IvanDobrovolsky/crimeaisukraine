          if (!finding) return null;
          let pkgs: any[] = [];
          if (eco.id === 'python_pypi') {
            pkgs = [...(finding.packages_high_level || []), ...(finding.packages_cpp_bindings || [])];
          } else if (eco.id === 'rust_cratesio') {
            pkgs = (finding.crates || []).map((c: any) => ({ package: c.crate, weekly_downloads: c.weekly_downloads, description: c.description }));
          } else if (eco.id === 'dotnet_nuget') {
            pkgs = (finding.packages || []).map((p: any) => ({ package: p.package, weekly_downloads: p.lifetime_downloads, description: p.description }));
          } else {
            pkgs = finding.packages || [];
          }
          pkgs = pkgs.sort((a: any, b: any) => (b.weekly_downloads || 0) - (a.weekly_downloads || 0));
          return (
            <div>
