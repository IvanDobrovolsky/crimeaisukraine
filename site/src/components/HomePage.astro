                <span class="text-[#e2e8f0] truncate text-xs font-medium">{f.platform}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Insight callout -->
    <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#0057b7]/30">
      <p class="text-sm text-[#94a3b8]">
        <span class="text-[#0057b7] font-bold">{lang === 'uk' ? 'Висновок' : 'Key insight'}:</span> {t.ipInsight}
