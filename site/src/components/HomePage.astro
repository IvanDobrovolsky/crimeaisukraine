<script define:vars={{ trends }}>
// Render Google Trends chart
function drawTrends() {
  const canvas = document.getElementById('trends-chart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const data = trends.is_sovereignty || [];
  if (!data.length) return;

  const W = canvas.width = canvas.offsetWidth * 2;
  const H = canvas.height = canvas.offsetHeight * 2;
  ctx.scale(2, 2);
  const w = W/2, h = H/2;
  const pad = { t: 10, r: 10, b: 25, l: 30 };
  const cw = w - pad.l - pad.r;
  const ch = h - pad.t - pad.b;

  ctx.fillStyle = '#111827';
  ctx.fillRect(0, 0, w, h);

  // Grid lines
  ctx.strokeStyle = '#1e293b';
  ctx.lineWidth = 0.5;
  for (let i = 0; i <= 4; i++) {
    const y = pad.t + ch * (1 - i/4);
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(w - pad.r, y); ctx.stroke();
    ctx.fillStyle = '#64748b'; ctx.font = '8px sans-serif';
    ctx.fillText(String(i * 25), 2, y + 3);
  }

  // Year labels
  const years = new Set();
  data.forEach((d, i) => {
    if (d.d && d.d.endsWith('-01')) {
      const year = d.d.split('-')[0];
      if (!years.has(year)) {
        years.add(year);
        const x = pad.l + (i / data.length) * cw;
        ctx.fillStyle = '#64748b'; ctx.font = '8px sans-serif';
        ctx.fillText(year, x - 10, h - 5);
      }
    }
  });

  // Draw lines
  function drawLine(key, color) {
    ctx.beginPath(); ctx.strokeStyle = color; ctx.lineWidth = 1.5;
    data.forEach((d, i) => {
      const x = pad.l + (i / data.length) * cw;
      const y = pad.t + ch * (1 - (d[key] || 0) / 100);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.stroke();
  }

  drawLine('ua', '#0057b7');
  drawLine('ru', '#ef4444');

  // 2014 and 2022 markers
  data.forEach((d, i) => {
    if (d.d === '2014-03' || d.d === '2022-02') {
      const x = pad.l + (i / data.length) * cw;
      ctx.strokeStyle = '#ffd700'; ctx.lineWidth = 0.5; ctx.setLineDash([3,3]);
      ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, pad.t + ch); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = '#ffd700'; ctx.font = '7px sans-serif';
      ctx.fillText(d.d === '2014-03' ? '2014 annexation' : '2022 invasion', x + 2, pad.t + 10);
    }
  });
}

// Render Ngrams chart
function drawNgrams() {
  const canvas = document.getElementById('ngrams-chart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const data = trends.framing || [];
  if (!data.length) return;

  const W = canvas.width = canvas.offsetWidth * 2;
  const H = canvas.height = canvas.offsetHeight * 2;
  ctx.scale(2, 2);
  const w = W/2, h = H/2;
  const pad = { t: 10, r: 10, b: 25, l: 30 };
  const cw = w - pad.l - pad.r;
  const ch = h - pad.t - pad.b;

  ctx.fillStyle = '#111827';
  ctx.fillRect(0, 0, w, h);

  const maxVal = Math.max(...data.map(d => Math.max(d.annexed || 0, d.russian || 0)));

  // Grid
  ctx.strokeStyle = '#1e293b'; ctx.lineWidth = 0.5;
  for (let i = 0; i <= 4; i++) {
    const y = pad.t + ch * (1 - i/4);
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(w - pad.r, y); ctx.stroke();
  }

  // Year labels
  const years = new Set();
  data.forEach((d, i) => {
    if (d.d && d.d.endsWith('-01')) {
      const year = d.d.split('-')[0];
      if (!years.has(year) && parseInt(year) % 2 === 0) {
        years.add(year);
        const x = pad.l + (i / data.length) * cw;
        ctx.fillStyle = '#64748b'; ctx.font = '8px sans-serif';
        ctx.fillText(year, x - 10, h - 5);
      }
    }
  });

  function drawLine(key, color) {
    ctx.beginPath(); ctx.strokeStyle = color; ctx.lineWidth = 1.5;
    data.forEach((d, i) => {
      const x = pad.l + (i / data.length) * cw;
      const y = pad.t + ch * (1 - (d[key] || 0) / (maxVal || 1));
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.stroke();
  }

  drawLine('annexed', '#22c55e');
  drawLine('russian', '#ef4444');

  // 2014 marker
  data.forEach((d, i) => {
    if (d.d === '2014-03') {
      const x = pad.l + (i / data.length) * cw;
      ctx.strokeStyle = '#ffd700'; ctx.lineWidth = 0.5; ctx.setLineDash([3,3]);
      ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, pad.t + ch); ctx.stroke();
      ctx.setLineDash([]);
    }
  });
}

setTimeout(() => { drawTrends(); drawNgrams(); }, 100);
window.addEventListener('resize', () => { drawTrends(); drawNgrams(); });
</script>
