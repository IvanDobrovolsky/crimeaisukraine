          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          {t.toolCTA}
        </a>
      </div>
      <div>
        <h3 class="text-sm font-bold text-[#6c6f85] uppercase tracking-wider mb-3">{t.toolCliTitle}</h3>
        <div class="bg-[#eff1f5] rounded-lg p-4 border border-[#ccd0da] font-mono text-xs space-y-2">
          <div class="text-[#6c6f85]"># {lang === 'uk' ? 'Класифікувати зображення' : 'Classify an image'}</div>
          <div class="text-[#4c4f69] font-semibold">sovereignmap --crimea screenshot.png</div>
          <div class="mt-3 text-[#6c6f85]"># {lang === 'uk' ? 'Сканувати відео' : 'Scan a video'}</div>
          <div class="text-[#4c4f69] font-semibold">sovereignmap --crimea --video clip.mp4</div>
          <div class="mt-3 text-[#6c6f85]"># YouTube</div>
          <div class="text-[#4c4f69] font-semibold">sovereignmap --crimea --youtube '<span class="text-[#6c6f85]">url</span>'</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Methodology section removed: the three-method findings-count cards
     (Source Code Inspection 18 · API Queries 76 · Automated Data 22)
     inherit the same unit-mismatch problem as the overview stats, and
     the "Sovereignty Classifier + Known Limitations" block is now
     documented per-pipeline in each README. The top-level methodology
     lives in the main repository README and in the briefing document. -->

<!-- "About This Research" section removed: the three summary cards
     repeated category counts ("120 platforms, 25 weather services, 13
     map services") that inherit the same unit-mismatch problem as the
     overview stats. Each pipeline section already documents its own
     scope at its own scale. -->

<!-- Footer -->
<footer class="max-w-6xl mx-auto px-3 sm:px-6 py-12 border-t border-[#ccd0da]">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
    <div>
      <p class="text-sm text-[#5c5f77]">
        {t.footerBy} <strong class="text-[#4c4f69]">{t.footerName}</strong>
      </p>
      <p class="text-xs text-[#6c6f85] mt-1">{t.footerRole}</p>
    </div>
    <div class="text-sm text-[#6c6f85]">
      <span>{T.footerData}</span>
    </div>
  </div>
</footer>

<script define:vars={{ mediaFilters, mediaTotals, mediaViolatorsByFilter, academic }}>
var currentFilter = 'international';

function lerp(a, b, t) { return a + (b - a) * t; }
function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

function drawChartFrame(id, pts, mx, events, p) {
  var c = document.getElementById(id);
  if (!c) return;
  var ctx = c.getContext('2d');
  var W = c.width = c.offsetWidth * 2;
  var H = c.height = c.offsetHeight * 2;
  ctx.scale(2, 2);
  var w = W/2, h = H/2;
  var cw = w-p.l-p.r, ch = h-p.t-p.b;
  ctx.fillStyle = '#e6e9ef';
  ctx.fillRect(0,0,w,h);
  if(!pts.length) return;
  ctx.strokeStyle='#ccd0da'; ctx.lineWidth=0.5;
  for(var i=0;i<=4;i++){var gy=p.t+ch*(1-i/4); ctx.beginPath();ctx.moveTo(p.l,gy);ctx.lineTo(w-p.r,gy);ctx.stroke(); ctx.fillStyle='#6c6f85';ctx.font='9px sans-serif'; var v=Math.round(mx*i/4); ctx.fillText(v>=1000?(v/1000).toFixed(1)+'K':v+'',2,gy+3);}
  var n=Math.max(pts.length-1,1);
  pts.forEach(function(pt,i){var x=p.l+(i/n)*cw; if(i%2===0||pts.length<=8){ctx.fillStyle='#6c6f85';ctx.font='9px sans-serif';ctx.fillText(pt.y,x-12,h-6);}});
  (events||[]).forEach(function(ey){var idx=-1;pts.forEach(function(pt,i){if(pt.y===ey)idx=i;});if(idx>=0){var x=p.l+(idx/n)*cw;ctx.strokeStyle='#df8e1d';ctx.lineWidth=0.8;ctx.setLineDash([4,3]);ctx.beginPath();ctx.moveTo(x,p.t);ctx.lineTo(x,p.t+ch);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='#df8e1d';ctx.font='8px sans-serif';ctx.fillText(ey,x+2,p.t+10);}});
  function line(key,color,fill){ctx.beginPath();pts.forEach(function(pt,i){var x=p.l+(i/n)*cw;var y=p.t+ch*(1-pt[key]/mx);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});var lx=p.l+cw;ctx.lineTo(lx,p.t+ch);ctx.lineTo(p.l,p.t+ch);ctx.closePath();ctx.fillStyle=fill;ctx.fill();ctx.beginPath();ctx.strokeStyle=color;ctx.lineWidth=2;pts.forEach(function(pt,i){var x=p.l+(i/n)*cw;var y=p.t+ch*(1-pt[key]/mx);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});ctx.stroke();pts.forEach(function(pt,i){var x=p.l+(i/n)*cw;var y=p.t+ch*(1-pt[key]/mx);ctx.beginPath();ctx.arc(x,y,2.5,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();});}
  line('ua','#40a02b','rgba(34,197,94,0.08)');
  line('ru','#d20f39','rgba(239,68,68,0.08)');
  line('disp','#df8e1d','rgba(245,158,11,0.05)');
}

function dataToPts(data) {
  return Object.keys(data).sort().map(function(y){var d=data[y]; return {y:y, ua:d.ukraine||0, ru:d.russia||0, disp:d.disputed||0};}).filter(function(x){return x.ua+x.ru+x.disp>0;});
}

function drawChart(id, data, events) {
  var pts = dataToPts(data);
  if(!pts.length) return;
  var mx = Math.max.apply(null, pts.map(function(x){return Math.max(x.ua,x.ru,x.disp);})) * 1.15;
  drawChartFrame(id, pts, mx, events, {t:15, r:15, b:28, l:45});
}

function animateChart(id, fromData, toData, events) {
  var fromPts = dataToPts(fromData);
  var toPts = dataToPts(toData);
  if (!fromPts.length || !toPts.length) { drawChart(id, toData, events); return; }
  var mxFrom = Math.max.apply(null, fromPts.map(function(x){return Math.max(x.ua,x.ru,x.disp);})) * 1.15;
  var mxTo = Math.max.apply(null, toPts.map(function(x){return Math.max(x.ua,x.ru,x.disp);})) * 1.15;
  var dur = 600, start = null, pad = {t:15, r:15, b:28, l:45};
  function frame(ts) {
    if (!start) start = ts;
    var raw = Math.min((ts - start) / dur, 1), t = easeOut(raw);
    var mx = lerp(mxFrom, mxTo, t);
    var interpPts = toPts.map(function(pt, i) {
      var fp = fromPts[i] || {y: pt.y, ua: 0, ru: 0, disp: 0};
      return {y: pt.y, ua: lerp(fp.ua, pt.ua, t), ru: lerp(fp.ru, pt.ru, t), disp: lerp(fp.disp, pt.disp, t)};
    });
    drawChartFrame(id, interpPts, mx, events, pad);
    if (raw < 1) requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
}

var filterHints = {
  international: 'BBC, Reuters, Al Jazeera, etc.',
  ukrainian: 'Kyiv Post, UNIAN, Ukrinform, etc.',
  russian: 'RIA, TASS, Sputnik, etc.',
  all: 'All 154K articles from GDELT'
};

function renderViolators(filter) {
  var list = document.getElementById('media-violators-list');
  var countEl = document.getElementById('media-violators-count');
  if (!list) return;
  var items = mediaViolatorsByFilter[filter] || mediaViolatorsByFilter.international || [];
  if (countEl) countEl.textContent = '(' + items.length + (items.length >= 100 ? '+' : '') + ')';
  list.style.opacity = '0';
  setTimeout(function() {
    list.innerHTML = '';
    items.slice(0, 50).forEach(function(v) {
      var row = document.createElement('div');
      row.className = 'flex items-center gap-2 text-[10px] py-1 border-b border-[#ccd0da]/30';
      var country = document.createElement('span');
      country.className = 'text-[#d20f39] flex-shrink-0 w-16';
      country.textContent = v.country || '?';
      var link = document.createElement('a');
      link.href = v.url;
      link.target = '_blank';
      link.rel = 'noopener';
      link.className = 'text-[#5c5f77] hover:text-[#4c4f69] truncate';
      link.textContent = v.domain + ' — ' + (v.signals || []).slice(0, 2).join(', ');
      row.appendChild(country);
      row.appendChild(link);
      list.appendChild(row);
    });
    list.style.transition = 'opacity 0.3s ease';
    list.style.opacity = '1';
  }, 150);
}

function setMediaFilter(filter) {
  if (filter === currentFilter) return;
  var prevData = mediaFilters[currentFilter];
  currentFilter = filter;
  var newData = mediaFilters[filter];
  var totals = mediaTotals[filter];
  // Update buttons
  document.querySelectorAll('.media-filter-btn').forEach(function(btn) {
    var f = btn.getAttribute('data-media-filter');
    btn.className = 'media-filter-btn px-3 py-1.5 text-xs rounded-lg font-medium transition-all ' +
      (f === filter ? 'bg-[#1e66f5] text-white' : 'bg-[#ccd0da] text-[#5c5f77] hover:bg-[#ccd0da]/80');
  });
  // Update stats
  var ua = document.getElementById('media-stat-ua');
  var ru = document.getElementById('media-stat-ru');
  var disp = document.getElementById('media-stat-disp');
  if (ua) ua.textContent = (totals.ukraine || 0).toLocaleString();
  if (ru) ru.textContent = (totals.russia || 0).toLocaleString();
  if (disp) disp.textContent = (totals.disputed || 0).toLocaleString();
  // Update hint
  var hint = document.getElementById('media-toggle-hint');
  if (hint) hint.textContent = filterHints[filter] || '';
  // Animate chart
  animateChart('media-chart', prevData, newData, ['2022']);
  // Update violators
  renderViolators(filter);
}

// Init filter buttons
setTimeout(function() {
  document.querySelectorAll('.media-filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      setMediaFilter(btn.getAttribute('data-media-filter'));
    });
  });
  renderViolators('international');
}, 50);

var acadData = academic.by_year_llm || academic.by_year;
setTimeout(function(){drawChart('media-chart',mediaFilters.international,['2022']);drawChart('academic-chart',acadData,['2014','2022']);},100);
window.addEventListener('resize',function(){drawChart('media-chart',mediaFilters[currentFilter],['2022']);drawChart('academic-chart',acadData,['2014','2022']);});
</script>
