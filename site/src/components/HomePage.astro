---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';
import platformsData from '../data/platforms.json';
import findingsUk from '../data/findings_uk.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];

const ukDetails = findingsUk as Record<string, string>;
const getDetail = (f: any) => lang === 'uk' ? (ukDetails[f.platform] || f.detail) : f.detail;

const findings = platformsData.findings || [];
const summary = (platformsData as any).summary || {};
const trends = (platformsData as any).trends || {};
const ipResults = (platformsData as any).ip_results || {};
const companiesSummary = (platformsData as any).companies_summary || {};

const total = findings.length;
const correct = findings.filter((f: any) => f.status === 'correct').length;
const incorrect = findings.filter((f: any) => f.status === 'incorrect').length;
const ambiguous = findings.filter((f: any) => f.status === 'ambiguous').length;
const blocked = findings.filter((f: any) => f.status === 'blocked').length;
const na = findings.filter((f: any) => f.status === 'n/a').length;

const categories = {} as Record<string, any[]>;
findings.forEach((f: any) => {
  if (!categories[f.category]) categories[f.category] = [];
  categories[f.category].push(f);
});

const categoryOrder = [
  'data_visualization', 'open_source', 'map_service', 'tech_infrastructure',
  'weather', 'reference', 'travel', 'ip_geolocation', 'social_media',
  'gaming', 'search_engine', 'sports', 'telecom'
];

const statusOrder = { correct: 0, incorrect: 1, ambiguous: 2, blocked: 3, 'n/a': 4 } as Record<string, number>;
const sortByStatus = (a: any, b: any) => (statusOrder[a.status] ?? 5) - (statusOrder[b.status] ?? 5);

const categoryLabels = t.categories;

// Chart percentages
const pCorrect = Math.round(correct / total * 100);
const pIncorrect = Math.round(incorrect / total * 100);
const pAmbiguous = Math.round(ambiguous / total * 100);
const pBlocked = Math.round(blocked / total * 100);
const pNA = Math.round(na / total * 100);

// Category stats for bar chart
const catStats = categoryOrder.filter(c => categories[c]).map(c => {
  const items = categories[c];
  return {
    name: (categoryLabels as any)[c] || c,
    total: items.length,
    correct: items.filter((f: any) => f.status === 'correct').length,
    incorrect: items.filter((f: any) => f.status === 'incorrect').length,
    ambiguous: items.filter((f: any) => f.status === 'ambiguous').length,
  };
});

// IP Geolocation — computed from enriched data
const ipData = ipResults as any;
const ipTotalLookups = ipData.total_lookups || 120;
const ipTotalIPs = ipData.total_ips || 90;
const ipTotalASNs = ipData.total_asns || 9;
const ipByCountry = ipData.by_country || { UA: 64, RU: 19, other: 37 };
const ipByProvider = ipData.by_provider || {};
const ipByASN = ipData.by_asn || {};
const ipTotalResults = (ipByCountry.UA || 0) + (ipByCountry.RU || 0) + (ipByCountry.other || 0);
const ipPctUA = Math.round((ipByCountry.UA || 0) / ipTotalResults * 100);
const ipPctRU = Math.round((ipByCountry.RU || 0) / ipTotalResults * 100);
const ipPctOther = Math.round((ipByCountry.other || 0) / ipTotalResults * 100);

// Sort ASNs: Ukrainian first, then mixed, then rerouted
const asnEntries = Object.entries(ipByASN).map(([id, info]: [string, any]) => ({ id, ...info }));
const asnSorted = asnEntries.sort((a: any, b: any) => {
  const order: Record<string, number> = { ukrainian: 0, mixed: 1, mixed_ru: 1, rerouted: 2 };
  return (order[a.origin] ?? 3) - (order[b.origin] ?? 3);
});

// Map services — computed from data
const mapFindings = findings.filter((f: any) => f.category === 'map_service');
const mCorrect = mapFindings.filter((f: any) => f.status === 'correct');
const mIncorrect = mapFindings.filter((f: any) => f.status === 'incorrect');
const mAmbiguous = mapFindings.filter((f: any) => f.status === 'ambiguous');
const mTotal = mapFindings.length;
const mPctCorrect = mTotal > 0 ? Math.round(mCorrect.length / mTotal * 100) : 0;
const mPctIncorrect = mTotal > 0 ? Math.round(mIncorrect.length / mTotal * 100) : 0;
const mPctAmbiguous = mTotal > 0 ? Math.round(mAmbiguous.length / mTotal * 100) : 0;

// Telecom — computed from data
const telecomFindings = findings.filter((f: any) => f.category === 'telecom');
const tcCorrect = telecomFindings.filter((f: any) => f.status === 'correct');
const tcIncorrect = telecomFindings.filter((f: any) => f.status === 'incorrect');
const tcBlocked = telecomFindings.filter((f: any) => f.status === 'blocked');
const tcNA = telecomFindings.filter((f: any) => f.status === 'n/a');
const tcTotal = telecomFindings.length;

// Tech infrastructure — computed from actual findings
const infraFindings = findings.filter((f: any) => f.category === 'tech_infrastructure');
const iCorrect = infraFindings.filter((f: any) => f.status === 'correct');
const iIncorrect = infraFindings.filter((f: any) => f.status === 'incorrect');
const iAmbiguous = infraFindings.filter((f: any) => f.status === 'ambiguous');
const iTotal = infraFindings.length;
const iPctCorrect = iTotal > 0 ? Math.round(iCorrect.length / iTotal * 100) : 0;
const iPctIncorrect = iTotal > 0 ? Math.round(iIncorrect.length / iTotal * 100) : 0;
const iPctAmbiguous = iTotal > 0 ? Math.round(iAmbiguous.length / iTotal * 100) : 0;

// Weather services — computed from actual data
const weatherFindings = findings.filter((f: any) => f.category === 'weather');
const wCorrect = weatherFindings.filter((f: any) => f.status === 'correct');
const wIncorrect = weatherFindings.filter((f: any) => f.status === 'incorrect');
const wAmbiguous = weatherFindings.filter((f: any) => f.status === 'ambiguous');
const wNA = weatherFindings.filter((f: any) => f.status === 'n/a');
const wTotal = weatherFindings.length;
const wPctCorrect = Math.round(wCorrect.length / wTotal * 100);
const wPctIncorrect = Math.round(wIncorrect.length / wTotal * 100);
const wPctAmbiguous = Math.round(wAmbiguous.length / wTotal * 100);
const wPctNA = Math.round(wNA.length / wTotal * 100);

const propagation = [
  { name: 'd3-geo', dl: '13.4M/wk', pct: 100, status: 'bad' },
  { name: 'Leaflet', dl: '4.2M/wk', pct: 31, status: 'bad' },
  { name: 'topojson-client', dl: '3.8M/wk', pct: 28, status: 'bad' },
  { name: 'ECharts', dl: '2.3M/wk', pct: 17, status: 'warn' },
  { name: 'Highcharts', dl: '2.3M/wk', pct: 17, status: 'good' },
  { name: 'Plotly.js', dl: '965K/wk', pct: 7, status: 'bad' },
];
---

<!-- Nav -->
<nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
  <div class="flex items-center gap-3">
    <div class="w-8 h-4 rounded-sm overflow-hidden flex flex-col">
      <div class="flex-1 bg-[#0057b7]"></div>
      <div class="flex-1 bg-[#ffd700]"></div>
    </div>
    <span class="text-sm font-medium text-[#94a3b8] tracking-wide">{t.siteName}</span>
  </div>
  <a href={t.altLang} class="text-sm font-medium text-[#64748b] hover:text-white border border-[#334155] px-3 py-1 rounded transition">
    {t.altLabel}
  </a>
</nav>

<!-- Hero -->
<header class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0057b7]/20 via-transparent to-[#ffd700]/10"></div>
  <div class="relative max-w-6xl mx-auto px-6 pt-12 pb-16">
    <h1 class="text-5xl md:text-7xl font-black leading-tight mb-6">
      <span class="text-[#0057b7]">{t.heroTitle1}</span><br />
      <span class="text-[#ffd700]">{t.heroTitle2}</span>
    </h1>

    <p class="text-xl md:text-2xl text-[#94a3b8] max-w-3xl mb-4" set:html={t.heroSub} />
    <p class="text-lg text-[#64748b] max-w-3xl mb-10" set:html={t.heroDesc} />

    <div class="flex flex-wrap gap-4">
      <a href="#findings" class="bg-[#0057b7] hover:bg-[#0057b7]/80 text-white font-semibold px-6 py-3 rounded-lg transition">
        {t.viewFindings}
      </a>
      <a href="https://github.com/IvanDobrovolskyi/crimeaisukraine" target="_blank" class="border border-[#334155] hover:border-[#94a3b8] text-[#94a3b8] font-semibold px-6 py-3 rounded-lg transition">
        {t.github}
      </a>
    </div>
  </div>
</header>

<!-- Stats + Donut Chart -->
<section class="max-w-6xl mx-auto px-6 mt-8 mb-16">
  <div class="grid md:grid-cols-[1fr_280px] gap-8 items-start">
    <!-- Stats Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      <div class="bg-[#111827] rounded-xl p-5 border border-[#1e293b]">
        <div class="text-3xl font-black text-white">{total}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statPlatforms}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#22c55e]/30">
        <div class="text-3xl font-black text-[#22c55e]">{correct}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statCorrect}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#ef4444]/30">
        <div class="text-3xl font-black text-[#ef4444]">{incorrect}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statIncorrect}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#f59e0b]/30">
        <div class="text-3xl font-black text-[#f59e0b]">{ambiguous}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statAmbiguous}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#8b5cf6]/30">
        <div class="text-3xl font-black text-[#8b5cf6]">{blocked}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statBlocked}</div>
      </div>
    </div>

    <!-- Donut Chart (CSS only) -->
    <div class="flex flex-col items-center">
      <div class="text-sm text-[#64748b] mb-3 font-medium">{t.chartTitle}</div>
      <div class="relative w-48 h-48">
        <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#1e293b" stroke-width="3.5" />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#22c55e" stroke-width="3.5"
            stroke-dasharray={`${pCorrect} ${100 - pCorrect}`} stroke-dashoffset="0" />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#ef4444" stroke-width="3.5"
            stroke-dasharray={`${pIncorrect} ${100 - pIncorrect}`} stroke-dashoffset={`${-pCorrect}`} />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#f59e0b" stroke-width="3.5"
            stroke-dasharray={`${pAmbiguous} ${100 - pAmbiguous}`} stroke-dashoffset={`${-(pCorrect + pIncorrect)}`} />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#8b5cf6" stroke-width="3.5"
            stroke-dasharray={`${pBlocked} ${100 - pBlocked}`} stroke-dashoffset={`${-(pCorrect + pIncorrect + pAmbiguous)}`} />
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-2xl font-black text-white">{total}</div>
          <div class="text-[10px] text-[#64748b]">platforms</div>
        </div>
      </div>
      <div class="flex flex-wrap gap-x-4 gap-y-1 mt-3 text-xs text-[#94a3b8] justify-center">
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>{t.chartCorrect}</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>{t.chartIncorrect}</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>{t.chartAmbiguous}</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#8b5cf6]"></span>{t.chartBlocked}</span>
      </div>
    </div>
  </div>
</section>

<!-- Category Bar Chart -->
<section class="max-w-6xl mx-auto px-6 mb-20">
  <div class="bg-[#111827] rounded-2xl p-6 md:p-8 border border-[#1e293b]">
    <h2 class="text-lg font-bold mb-6">{t.chartTitle} by Category</h2>
    <div class="space-y-3">
      {catStats.map(cat => {
        const maxLen = Math.max(...catStats.map(c => c.total));
        const scale = 100 / maxLen;
        return (
          <div class="flex items-center gap-3">
            <div class="w-32 md:w-44 text-xs text-[#94a3b8] text-right truncate flex-shrink-0">{cat.name}</div>
            <div class="flex-1 flex h-5 rounded-full overflow-hidden bg-[#0a0e1a]">
              {cat.correct > 0 && <div class="bg-[#22c55e] h-full" style={`width: ${cat.correct * scale}%`}></div>}
              {cat.incorrect > 0 && <div class="bg-[#ef4444] h-full" style={`width: ${cat.incorrect * scale}%`}></div>}
              {cat.ambiguous > 0 && <div class="bg-[#f59e0b] h-full" style={`width: ${cat.ambiguous * scale}%`}></div>}
            </div>
            <div class="w-6 text-xs text-[#64748b] flex-shrink-0">{cat.total}</div>
          </div>
        );
      })}
    </div>
    <div class="flex gap-4 mt-4 text-xs text-[#64748b]">
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>{t.chartCorrect}</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>{t.chartIncorrect}</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>{t.chartAmbiguous}</span>
    </div>
  </div>
</section>

<!-- Propagation Chain -->
<section class="max-w-6xl mx-auto px-6 mb-20">
  <div class="bg-gradient-to-r from-[#ef4444]/10 to-[#111827] border border-[#ef4444]/30 rounded-2xl p-8 md:p-12">
    <h2 class="text-2xl md:text-3xl font-bold mb-6">{t.rootCauseTitle}</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <p class="text-[#94a3b8] mb-4" set:html={t.rootCauseP1} />
        <p class="text-[#94a3b8] mb-4" set:html={t.rootCauseP2} />
        <p class="text-[#94a3b8]" set:html={t.rootCauseP3} />
      </div>
      <div class="space-y-3">
        <div class="text-sm text-[#64748b] mb-2 uppercase tracking-wider">{t.weeklyDownloads}</div>
        {propagation.map(item => (
          <div class="flex items-center gap-3">
            <div class={`w-2 h-2 rounded-full flex-shrink-0 ${item.status === 'good' ? 'bg-[#22c55e]' : item.status === 'warn' ? 'bg-[#f59e0b]' : 'bg-[#ef4444]'}`}></div>
            <div class={`flex-1 bg-[#0a0e1a] rounded-lg border overflow-hidden ${item.status === 'good' ? 'border-[#22c55e]/30' : 'border-[#1e293b]'}`}>
              <div class="flex items-center justify-between px-4 py-2">
                <span class={`text-sm font-medium ${item.status === 'good' ? 'text-[#22c55e]' : 'text-white'}`}>{item.name}</span>
                <span class={`text-xs ${item.status === 'good' ? 'text-[#22c55e]' : 'text-[#64748b]'}`}>{item.dl}{item.status === 'good' ? ' \u2014 Correct!' : ''}</span>
              </div>
              <div class={`h-1 ${item.status === 'good' ? 'bg-[#22c55e]' : item.status === 'warn' ? 'bg-[#f59e0b]' : 'bg-[#ef4444]'}`} style={`width: ${item.pct}%`}></div>
            </div>
          </div>
        ))}
        <div class="text-right text-sm text-[#f59e0b] font-bold mt-4">{t.totalAffected}</div>
      </div>
    </div>
  </div>
</section>

<!-- Google Trends Chart -->
<section class="max-w-6xl mx-auto px-6 mb-20">
  <div class="bg-[#111827] rounded-2xl p-6 md:p-8 border border-[#1e293b]">
    <h2 class="text-lg font-bold mb-2">{lang === 'uk' ? 'Пошукові тренди: «Крим — це Україна» vs «Крим — це Росія»' : 'Search Trends: "Crimea is Ukraine" vs "Crimea is Russia"'}</h2>
    <p class="text-xs text-[#64748b] mb-4">{lang === 'uk' ? 'Google Trends, щомісячно, 2013–2026. 100 = пікова популярність.' : 'Google Trends, monthly, 2013–2026. 100 = peak popularity.'}</p>
    <div class="relative" style="height: 200px;">
      <canvas id="trends-chart" width="800" height="200" class="w-full h-full"></canvas>
    </div>
    <div class="flex gap-6 mt-3 text-xs">
      <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-[#0057b7] inline-block"></span>{lang === 'uk' ? '«Крим — це Україна»' : '"Crimea is Ukraine"'}</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-[#ef4444] inline-block"></span>{lang === 'uk' ? '«Крим — це Росія»' : '"Crimea is Russia"'}</span>
    </div>
  </div>
</section>

<!-- Ngrams Chart -->
<section class="max-w-6xl mx-auto px-6 mb-20">
  <div class="bg-[#111827] rounded-2xl p-6 md:p-8 border border-[#1e293b]">
    <h2 class="text-lg font-bold mb-2">{lang === 'uk' ? 'У книгах: «анексований Крим» vs «російський Крим»' : 'In Books: "Annexed Crimea" vs "Russian Crimea"'}</h2>
    <p class="text-xs text-[#64748b] mb-4">{lang === 'uk' ? 'Google Ngrams (англомовні книги), 1950–2019. Автори використовують правильне формулювання.' : 'Google Ngrams (English books), 1950–2019. Authors use the correct framing.'}</p>
    <div class="relative" style="height: 200px;">
      <canvas id="ngrams-chart" width="800" height="200" class="w-full h-full"></canvas>
    </div>
    <div class="flex gap-6 mt-3 text-xs">
      <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-[#22c55e] inline-block"></span>{lang === 'uk' ? '«Анексований Крим»' : '"Annexed Crimea"'}</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-[#ef4444] inline-block"></span>{lang === 'uk' ? '«Російський Крим»' : '"Russian Crimea"'}</span>
    </div>
  </div>
</section>

<!-- Map Services — Expanded Section -->
<section id="map-services" class="max-w-6xl mx-auto px-6 mb-20">
  <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-8 md:p-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">{t.mapTitle}</h2>
    <p class="text-[#94a3b8] mb-8">{t.mapDesc}</p>

    <!-- Top row: Donut + Stats -->
    <div class="grid md:grid-cols-[240px_1fr] gap-8 mb-10">
      <div class="flex flex-col items-center">
        <div class="relative w-44 h-44">
          <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#1e293b" stroke-width="3.8" />
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#22c55e" stroke-width="3.8"
              stroke-dasharray={`${mPctCorrect} ${100 - mPctCorrect}`} stroke-dashoffset="0" />
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#ef4444" stroke-width="3.8"
              stroke-dasharray={`${mPctIncorrect} ${100 - mPctIncorrect}`} stroke-dashoffset={`${-mPctCorrect}`} />
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#f59e0b" stroke-width="3.8"
              stroke-dasharray={`${mPctAmbiguous} ${100 - mPctAmbiguous}`} stroke-dashoffset={`${-(mPctCorrect + mPctIncorrect)}`} />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div class="text-3xl font-black text-white">{mTotal}</div>
            <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'сервісів' : 'services'}</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-x-3 gap-y-1 mt-4 text-xs text-[#94a3b8] justify-center">
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>{mCorrect.length} {t.mapCorrectLabel}</span>
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>{mIncorrect.length} {t.mapIncorrectLabel}</span>
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>{mAmbiguous.length} {t.mapAmbiguousLabel}</span>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#22c55e]/30 text-center">
          <div class="text-3xl font-black text-[#22c55e]">{mCorrect.length}</div>
          <div class="text-xs text-[#94a3b8] mt-1">{t.mapCorrectLabel}</div>
          <div class="text-[10px] text-[#64748b] mt-0.5">{mPctCorrect}%</div>
        </div>
        <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#ef4444]/30 text-center">
          <div class="text-3xl font-black text-[#ef4444]">{mIncorrect.length}</div>
          <div class="text-xs text-[#94a3b8] mt-1">{t.mapIncorrectLabel}</div>
          <div class="text-[10px] text-[#64748b] mt-0.5">{mPctIncorrect}%</div>
        </div>
        <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#f59e0b]/30 text-center">
          <div class="text-3xl font-black text-[#f59e0b]">{mAmbiguous.length}</div>
          <div class="text-xs text-[#94a3b8] mt-1">{t.mapAmbiguousLabel}</div>
          <div class="text-[10px] text-[#64748b] mt-0.5">{mPctAmbiguous}%</div>
        </div>
      </div>
    </div>

    <!-- Grouped service listings -->
    <div class="space-y-6">
      <!-- Correct: Geocoding APIs -->
      <div>
        <h3 class="text-sm font-bold text-[#22c55e] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>
          {t.mapGeocodingTitle} ({mCorrect.length})
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">
          {mCorrect.sort((a: any, b: any) => a.platform.localeCompare(b.platform)).map((f: any) => (
