                    </span>
                    <span class={`font-mono ${p.package === 'highcharts' ? 'text-[#40a02b]' : 'text-[#6c6f85]'}`}>
                      {p.weekly_downloads ? p.weekly_downloads.toLocaleString() : '—'} /wk
                    </span>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
