  <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-8 md:p-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">{t.infraTitle}</h2>
    <p class="text-[#94a3b8] mb-8">{t.infraDesc}</p>

    <!-- Donut + Stats (same pattern as other sections) -->
    <div class="grid md:grid-cols-[240px_1fr] gap-8 mb-10">
      <div class="flex flex-col items-center">
        <div class="relative w-44 h-44">
          <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#1e293b" stroke-width="3.8" />
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#22c55e" stroke-width="3.8"
              stroke-dasharray={`${iPctCorrect} ${100 - iPctCorrect}`} stroke-dashoffset="0" />
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#ef4444" stroke-width="3.8"
              stroke-dasharray={`${iPctIncorrect} ${100 - iPctIncorrect}`} stroke-dashoffset={`${-iPctCorrect}`} />
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#f59e0b" stroke-width="3.8"
              stroke-dasharray={`${iPctAmbiguous} ${100 - iPctAmbiguous}`} stroke-dashoffset={`${-(iPctCorrect + iPctIncorrect)}`} />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div class="text-3xl font-black text-white">{iTotal}</div>
            <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'систем' : 'systems'}</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-x-3 gap-y-1 mt-4 text-xs text-[#94a3b8] justify-center">
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>{iCorrect.length} {t.infraLegal}</span>
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>{iIncorrect.length} {t.infraOp}</span>
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>{iAmbiguous.length} {lang === 'uk' ? 'Розщеплено' : 'Split'}</span>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#22c55e]/30 text-center">
          <div class="text-3xl font-black text-[#22c55e]">{iCorrect.length}</div>
          <div class="text-xs text-[#94a3b8] mt-1">{t.infraLegal}</div>
          <div class="text-[10px] text-[#64748b] mt-0.5">{iPctCorrect}%</div>
        </div>
        <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#ef4444]/30 text-center">
          <div class="text-3xl font-black text-[#ef4444]">{iIncorrect.length}</div>
          <div class="text-xs text-[#94a3b8] mt-1">{t.infraOp}</div>
          <div class="text-[10px] text-[#64748b] mt-0.5">{iPctIncorrect}%</div>
        </div>
        <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#f59e0b]/30 text-center">
          <div class="text-3xl font-black text-[#f59e0b]">{iAmbiguous.length}</div>
          <div class="text-xs text-[#94a3b8] mt-1">{lang === 'uk' ? 'Розщеплено' : 'Split'}</div>
          <div class="text-[10px] text-[#64748b] mt-0.5">{iPctAmbiguous}%</div>
        </div>
      </div>
    </div>

    <!-- Grouped listings -->
    <div class="space-y-6">
      <!-- Correct (Ukraine) -->
      <div>
        <h3 class="text-sm font-bold text-[#22c55e] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>
          {t.infraLegal} ({iCorrect.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {iCorrect.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#22c55e]/20">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#22c55e] flex-shrink-0 text-xs">&#x2713;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Ambiguous (Split) -->
      <div>
        <h3 class="text-sm font-bold text-[#f59e0b] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>
          {lang === 'uk' ? 'Розщеплена ідентичність' : 'Split Identity'} ({iAmbiguous.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {iAmbiguous.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#f59e0b]/20">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#f59e0b] flex-shrink-0 text-xs">&#x26A0;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Incorrect (Russia) -->
      <div>
        <h3 class="text-sm font-bold text-[#ef4444] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>
          {t.infraOp} ({iIncorrect.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {iIncorrect.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#ef4444]/20">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#ef4444] flex-shrink-0 text-xs">&#x2717;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Internet & Telecommunications Section -->
<section id="telecom" class="max-w-6xl mx-auto px-6 mb-12">
  <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-8 md:p-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">{t.telecomTitle}</h2>
    <p class="text-[#94a3b8] mb-8">{t.telecomDesc}</p>

    <!-- Stat overview -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
      <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#64748b]/30 text-center">
        <div class="text-3xl font-black text-[#64748b]">{tcNA.length}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.telecomUaTitle}</div>
      </div>
      <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#ef4444]/30 text-center">
        <div class="text-3xl font-black text-[#ef4444]">{tcIncorrect.length}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.telecomRuTitle}</div>
      </div>
      <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#8b5cf6]/30 text-center">
        <div class="text-3xl font-black text-[#8b5cf6]">{tcBlocked.length}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.telecomBlockedTitle}</div>
      </div>
      <div class="bg-[#0a0e1a] rounded-xl p-4 border border-[#22c55e]/30 text-center">
        <div class="text-3xl font-black text-[#22c55e]">{tcCorrect.length}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.telecomSurvivingTitle}</div>
      </div>
    </div>

    <!-- Grouped listings -->
    <div class="space-y-6">
      <!-- Ukrainian operators (withdrawn) -->
      {tcNA.length > 0 && (
      <div>
        <h3 class="text-sm font-bold text-[#64748b] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#64748b]"></span>
          {t.telecomUaTitle} ({tcNA.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
          {tcNA.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#64748b]/20">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#64748b] flex-shrink-0 text-xs">&#x2796;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>
      )}

      <!-- Russian infrastructure -->
      {tcIncorrect.length > 0 && (
      <div>
        <h3 class="text-sm font-bold text-[#ef4444] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>
          {t.telecomRuTitle} ({tcIncorrect.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {tcIncorrect.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#ef4444]/20">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#ef4444] flex-shrink-0 text-xs">&#x2717;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>
      )}

      <!-- Sanctions-blocked -->
      {tcBlocked.length > 0 && (
      <div>
        <h3 class="text-sm font-bold text-[#8b5cf6] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#8b5cf6]"></span>
          {t.telecomBlockedTitle} ({tcBlocked.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
          {tcBlocked.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#8b5cf6]/20">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#8b5cf6] flex-shrink-0 text-xs">&#x1F6AB;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>
      )}

      <!-- Surviving Ukrainian -->
      {tcCorrect.length > 0 && (
      <div>
        <h3 class="text-sm font-bold text-[#22c55e] uppercase tracking-wider mb-3 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>
          {t.telecomSurvivingTitle} ({tcCorrect.length})
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {tcCorrect.map((f: any) => (
            <div class="bg-[#0a0e1a] rounded-lg px-3 py-2.5 text-sm border border-[#22c55e]/30">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#22c55e] flex-shrink-0 text-xs">&#x2713;</span>
                <span class="text-[#e2e8f0] text-xs font-medium">{f.platform}</span>
              </div>
              <div class="text-[10px] text-[#64748b] leading-tight pl-4">{f.detail.length > 200 ? f.detail.slice(0, 200) + '...' : f.detail}</div>
            </div>
          ))}
        </div>
      </div>
      )}
    </div>

    <!-- Insight -->
    <div class="mt-8 bg-[#0a0e1a] rounded-xl p-4 border border-[#ef4444]/30">
      <p class="text-sm text-[#94a3b8]">
        <span class="text-[#ef4444] font-bold">{lang === 'uk' ? 'Висновок' : 'Key insight'}:</span> {t.telecomInsight}
      </p>
    </div>
  </div>
</section>

<!-- Propagation Chain — The Root Cause -->
<section class="max-w-6xl mx-auto px-6 mb-12">
  <div class="bg-gradient-to-r from-[#ef4444]/10 to-[#111827] border border-[#ef4444]/30 rounded-2xl p-8 md:p-12">
    <h2 class="text-2xl md:text-3xl font-bold mb-6">{t.rootCauseTitle}</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <p class="text-[#94a3b8] mb-4" set:html={t.rootCauseP1} />
        <p class="text-[#94a3b8] mb-4" set:html={t.rootCauseP2} />
        <p class="text-[#94a3b8]" set:html={t.rootCauseP3} />
      </div>
      <div class="space-y-3">
        <div class="text-sm text-[#64748b] mb-2 uppercase tracking-wider">{t.weeklyDownloads}</div>
        {propagation.map(item => (
          <div class="flex items-center gap-3">
            <div class={`w-2 h-2 rounded-full flex-shrink-0 ${item.status === 'good' ? 'bg-[#22c55e]' : item.status === 'warn' ? 'bg-[#f59e0b]' : 'bg-[#ef4444]'}`}></div>
            <div class={`flex-1 bg-[#0a0e1a] rounded-lg border overflow-hidden ${item.status === 'good' ? 'border-[#22c55e]/30' : 'border-[#1e293b]'}`}>
              <div class="flex items-center justify-between px-4 py-2">
                <span class={`text-sm font-medium ${item.status === 'good' ? 'text-[#22c55e]' : 'text-white'}`}>{item.name}</span>
                <span class={`text-xs ${item.status === 'good' ? 'text-[#22c55e]' : 'text-[#64748b]'}`}>{item.dl}{item.status === 'good' ? ' \u2014 Correct!' : ''}</span>
              </div>
              <div class={`h-1 ${item.status === 'good' ? 'bg-[#22c55e]' : item.status === 'warn' ? 'bg-[#f59e0b]' : 'bg-[#ef4444]'}`} style={`width: ${item.pct}%`}></div>
            </div>
          </div>
        ))}
        <div class="text-right text-sm text-[#f59e0b] font-bold mt-4">{t.totalAffected}</div>
      </div>
    </div>
  </div>
</section>

<!-- 2022 Bifurcation -->
<section class="max-w-6xl mx-auto px-6 mb-12">
  <h2 class="text-2xl md:text-3xl font-bold mb-4">{t.bifurcationTitle}</h2>
  <p class="text-[#94a3b8] max-w-3xl mb-8">{t.bifurcationDesc}</p>
  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-[#111827] rounded-xl p-6 border border-[#22c55e]/30">
      <h3 class="text-lg font-bold text-[#22c55e] mb-4">{t.changedTitle}</h3>
      <ul class="space-y-2 text-sm text-[#94a3b8]">
        {t.changed.map(item => <li class="flex gap-2"><span class="text-[#22c55e] flex-shrink-0">&#x2713;</span><span>{item}</span></li>)}
      </ul>
    </div>
    <div class="bg-[#111827] rounded-xl p-6 border border-[#ef4444]/30">
      <h3 class="text-lg font-bold text-[#ef4444] mb-4">{t.unchangedTitle}</h3>
      <ul class="space-y-2 text-sm text-[#94a3b8]">
        {t.unchanged.map(item => <li class="flex gap-2"><span class="text-[#ef4444] flex-shrink-0">&#x2717;</span><span>{item}</span></li>)}
      </ul>
    </div>
  </div>
</section>

<!-- SovereignMap Tool -->
<section id="tool" class="max-w-6xl mx-auto px-6 mb-12">
  <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-8 md:p-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">{t.toolTitle}</h2>
    <p class="text-[#94a3b8] mb-8">{t.toolDesc}</p>

    <!-- Demo: 4 rows, full width -->
    <div class="space-y-3 mb-8">
      <div class="rounded-lg overflow-hidden border border-[#22c55e]/30">
        <img src="/card_ukraine.png" alt="UKRAINE — Crimea same color as Ukraine, 93% confidence" class="w-full" loading="lazy" />
      </div>
      <div class="rounded-lg overflow-hidden border border-[#ef4444]/30">
        <img src="/card_russia.png" alt="RUSSIA — Crimea same color as Russia, 85% confidence" class="w-full" loading="lazy" />
      </div>
      <div class="rounded-lg overflow-hidden border border-[#f59e0b]/30">
        <img src="/card_disputed.png" alt="DISPUTED — dashed border or hatching, 65% confidence" class="w-full" loading="lazy" />
      </div>
      <div class="rounded-lg overflow-hidden border border-[#64748b]/30">
        <img src="/card_unknown.png" alt="UNKNOWN — no political coloring, 40% confidence" class="w-full" loading="lazy" />
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <p class="text-[#94a3b8] mb-4 text-sm">{t.toolHow}</p>
