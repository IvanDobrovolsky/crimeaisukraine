---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';
import platformsData from '../data/platforms.json';
import manifest from '../data/manifest.json';
import framingData from '../data/framing.json';
import mediaViolators from '../data/media_violators.json';
import findingsUk from '../data/findings_uk.json';
import auditData from '../data/llm_audit_results.json';
import modelsData from '../data/llm_models.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
const m = manifest as any;

// Template variable replacer — substitutes {key} with manifest values
const vars: Record<string, string> = {
  total: String(m.global.total_platforms),
  categories: String(m.global.total_categories),
  source_code: String(m.methodology.source_code),
  automated_api: String(m.methodology.automated_api),
  automated_data: String(m.methodology.automated_data),
  ip_ips: String(m.ip_geolocation.total_ips_tested),
  ip_asns: String(m.ip_geolocation.total_asns_tested),
  weather_total: String(m.weather.total),
};
const fill = (s: string) => s.replace(/\{(\w+)\}/g, (_, k) => vars[k] ?? `{${k}}`);

// Override t with filled values for keys that have templates
const tFilled = new Proxy(t, {
  get(target, prop: string) {
    const val = (target as any)[prop];
    return typeof val === 'string' ? fill(val) : val;
  }
});
// Use tFilled for display, keep t for non-string access
const T = tFilled as typeof t;

const ukDetails = findingsUk as Record<string, string>;
const getDetail = (f: any) => lang === 'uk' ? (ukDetails[f.platform] || f.detail) : f.detail;

const findings = platformsData.findings || [];
const trends = (platformsData as any).trends || {};
const ipResults = (platformsData as any).ip_results || {};

// --- Global stats from manifest ---
const total = m.global.total_platforms;
const correct = m.global.by_status.correct || 0;
const incorrect = m.global.by_status.incorrect || 0;
const ambiguous = m.global.by_status.ambiguous || 0;
const blocked = m.global.by_status.blocked || 0;
const na = m.global.by_status['n/a'] || 0;

// Group findings by category (still needed for listings)
const categories = {} as Record<string, any[]>;
findings.forEach((f: any) => {
  if (!categories[f.category]) categories[f.category] = [];
  categories[f.category].push(f);
});

const categoryOrder = [
  'data_visualization', 'open_source', 'map_service', 'tech_infrastructure',
  'weather', 'reference', 'travel', 'ip_geolocation',
  'search_engine', 'telecom'
];

const statusOrder = { correct: 0, incorrect: 1, ambiguous: 2, blocked: 3, 'n/a': 4 } as Record<string, number>;
const sortByStatus = (a: any, b: any) => (statusOrder[a.status] ?? 5) - (statusOrder[b.status] ?? 5);
const categoryLabels = t.categories;

// --- Chart percentages from manifest ---
const pCorrect = Math.round(correct / total * 100);
const pIncorrect = Math.round(incorrect / total * 100);
const pAmbiguous = Math.round(ambiguous / total * 100);
const pBlocked = Math.round(blocked / total * 100);
const pNA = Math.round(na / total * 100);

// Category bar chart — from manifest
const catStats = categoryOrder.filter(c => m.by_category[c]).map(c => ({
  name: (categoryLabels as any)[c] || c,
  total: m.by_category[c].total,
  correct: m.by_category[c].correct,
  incorrect: m.by_category[c].incorrect,
  ambiguous: m.by_category[c].ambiguous,
}));

// --- Helper: get category findings + stats from manifest ---
const catFindings = (cat: string) => findings.filter((f: any) => f.category === cat);
const cs = (cat: string) => m[cat] || m.by_category[cat] || { total: 0, correct: 0, incorrect: 0, ambiguous: 0, blocked: 0, 'n/a': 0 };
const pct = (n: number, t: number) => t > 0 ? Math.round(n / t * 100) : 0;

// --- Per-section data (findings + manifest stats) ---
// Weather
const weatherFindings = catFindings('weather');
const wS = cs('weather');
const wCorrect = weatherFindings.filter((f: any) => f.status === 'correct');
const wIncorrect = weatherFindings.filter((f: any) => f.status === 'incorrect');
const wAmbiguous = weatherFindings.filter((f: any) => f.status === 'ambiguous');
const wNA = weatherFindings.filter((f: any) => f.status === 'n/a');
const wTotal = wS.total;
const wPctCorrect = pct(wS.correct, wTotal);
const wPctIncorrect = pct(wS.incorrect, wTotal);
const wPctAmbiguous = pct(wS.ambiguous, wTotal);
const wPctNA = pct(wS['n/a'], wTotal);

// Map services
const mapFindings = catFindings('map_service');
const mS = cs('map_service');
const mCorrect = mapFindings.filter((f: any) => f.status === 'correct');
const mIncorrect = mapFindings.filter((f: any) => f.status === 'incorrect');
const mAmbiguous = mapFindings.filter((f: any) => f.status === 'ambiguous');
const mTotal = mS.total;
const mPctCorrect = pct(mS.correct, mTotal);
const mPctIncorrect = pct(mS.incorrect, mTotal);
const mPctAmbiguous = pct(mS.ambiguous, mTotal);

// IP Geolocation
const ipM = m.ip_geolocation;
const ipTotalLookups = ipM.total_lookups;
const ipTotalIPs = ipM.total_ips_tested;
const ipTotalASNs = ipM.total_asns_tested;
const ipByCountry = ipM.by_country;
const ipByProvider = ipResults.by_provider || {};
const ipByASN = ipResults.by_asn || {};
const ipPctUA = ipM.pct_ua;
const ipPctRU = ipM.pct_ru;
const ipPctOther = ipM.pct_other;
const asnEntries = Object.entries(ipByASN).map(([id, info]: [string, any]) => ({ id, ...info }));
const asnSorted = asnEntries.sort((a: any, b: any) => {
  const order: Record<string, number> = { ukrainian: 0, mixed: 1, mixed_ru: 1, rerouted: 2 };
  return (order[a.origin] ?? 3) - (order[b.origin] ?? 3);
});

// Telecom
const telecomFindings = catFindings('telecom');
const tcS = cs('telecom');
const tcCorrect = telecomFindings.filter((f: any) => f.status === 'correct');
const tcIncorrect = telecomFindings.filter((f: any) => f.status === 'incorrect');
const tcBlocked = telecomFindings.filter((f: any) => f.status === 'blocked');
const tcNA = telecomFindings.filter((f: any) => f.status === 'n/a');

// Tech infrastructure
const infraFindings = catFindings('tech_infrastructure');
const iS = cs('tech_infrastructure');
const iCorrect = infraFindings.filter((f: any) => f.status === 'correct');
const iIncorrect = infraFindings.filter((f: any) => f.status === 'incorrect');
const iAmbiguous = infraFindings.filter((f: any) => f.status === 'ambiguous');
const iTotal = iS.total;
const iPctCorrect = pct(iS.correct, iTotal);
const iPctIncorrect = pct(iS.incorrect, iTotal);
const iPctAmbiguous = pct(iS.ambiguous, iTotal);

// Framing data
const fd = framingData as any;
const gdelt = fd.gdelt;
const academic = fd.academic;

// Media year-by-year for chart — 4 filter views
const byFilter = (fd.gdelt as any).by_year_by_filter || {};

function transformCorrected(data: any) {
  const out: any = {};
  for (const [y, d] of Object.entries(data as Record<string, any>)) {
    out[y] = { ukraine: d.ukraine || 0, russia: d.russia_corrected ?? d.russia ?? 0, disputed: d.disputed || 0 };
  }
  return out;
}

const mediaFilters: Record<string, any> = {
  international: transformCorrected(byFilter.international || {}),
  ukrainian: transformCorrected(byFilter.ukrainian || {}),
  russian: transformCorrected(byFilter.russian || {}),
  all: transformCorrected(byFilter.all || {}),
};

function computeTotals(data: any) {
  return Object.values(data as Record<string, any>).reduce(
    (acc: any, d: any) => ({ ukraine: acc.ukraine + (d.ukraine||0), russia: acc.russia + (d.russia||0), disputed: acc.disputed + (d.disputed||0) }),
    { ukraine: 0, russia: 0, disputed: 0 }
  );
}

const mediaTotals: Record<string, any> = {
  international: computeTotals(mediaFilters.international),
  ukrainian: computeTotals(mediaFilters.ukrainian),
  russian: computeTotals(mediaFilters.russian),
  all: computeTotals(mediaFilters.all),
};

const gdeltByYear = mediaFilters.international; // default
const mediaYears = Object.keys(mediaFilters.all).filter((y: string) => y >= '2015').sort();
const acadYears = Object.keys(academic.by_year).filter(y => y >= '2012').sort();

// Academic violators
const acadViolators = academic.violators || [];

// Media violators by filter (imported from media_violators.json)
const mediaViolatorsByFilter = mediaViolators as any;

const propagation = [
  { name: 'd3-geo', dl: '13.4M/wk', pct: 100, status: 'bad' },
  { name: 'Leaflet', dl: '4.2M/wk', pct: 31, status: 'bad' },
  { name: 'topojson-client', dl: '3.8M/wk', pct: 28, status: 'bad' },
  { name: 'ECharts', dl: '2.3M/wk', pct: 17, status: 'warn' },
  { name: 'Highcharts', dl: '2.3M/wk', pct: 17, status: 'good' },
  { name: 'Plotly.js', dl: '965K/wk', pct: 7, status: 'bad' },
];
---

<!-- Nav -->
<nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
  <div class="flex items-center gap-3">
    <div class="w-8 h-4 rounded-sm overflow-hidden flex flex-col">
      <div class="flex-1 bg-[#0057b7]"></div>
      <div class="flex-1 bg-[#ffd700]"></div>
    </div>
    <span class="text-sm font-medium text-[#94a3b8] tracking-wide">{t.siteName}</span>
  </div>
  <div class="flex items-center gap-3">
    <a href="https://github.com/IvanDobrovolsky/crimeaisukraine" target="_blank" class="text-sm text-[#64748b] hover:text-white transition flex items-center gap-1.5">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      GitHub
    </a>
    <a href={t.altLang} class="text-sm font-medium text-[#64748b] hover:text-white border border-[#334155] px-3 py-1 rounded transition">
      {t.altLabel}
    </a>
  </div>
</nav>

<!-- Hero -->
<header class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0057b7]/20 via-transparent to-[#ffd700]/10"></div>
  <div class="relative max-w-6xl mx-auto px-6 pt-12 pb-16">
    <h1 class="text-5xl md:text-7xl font-black leading-tight mb-6">
      <span class="text-[#0057b7]">{t.heroTitle1}</span><br />
      <span class="text-[#ffd700]">{t.heroTitle2}</span>
    </h1>

    <p class="text-xl md:text-2xl text-[#94a3b8] max-w-3xl mb-4" set:html={T.heroSub} />
    <p class="text-lg text-[#64748b] max-w-3xl" set:html={T.heroDesc} />
  </div>
</header>

<!-- Stats + Donut Chart -->
<section class="max-w-6xl mx-auto px-6 mt-8 mb-16">
  <div class="grid md:grid-cols-[1fr_280px] gap-8 items-start">
    <!-- Stats Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      <div class="bg-[#111827] rounded-xl p-5 border border-[#1e293b]">
        <div class="text-3xl font-black text-white">{total}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statPlatforms}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#22c55e]/30">
        <div class="text-3xl font-black text-[#22c55e]">{correct}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statCorrect}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#ef4444]/30">
        <div class="text-3xl font-black text-[#ef4444]">{incorrect}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statIncorrect}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#f59e0b]/30">
        <div class="text-3xl font-black text-[#f59e0b]">{ambiguous}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statAmbiguous}</div>
      </div>
      <div class="bg-[#111827] rounded-xl p-5 border border-[#8b5cf6]/30">
        <div class="text-3xl font-black text-[#8b5cf6]">{blocked}</div>
        <div class="text-xs text-[#94a3b8] mt-1">{t.statBlocked}</div>
      </div>
    </div>

    <!-- Donut Chart (CSS only) -->
    <div class="flex flex-col items-center">
      <div class="text-sm text-[#64748b] mb-3 font-medium">{t.chartTitle}</div>
      <div class="relative w-48 h-48">
        <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#1e293b" stroke-width="3.5" />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#22c55e" stroke-width="3.5"
            stroke-dasharray={`${pCorrect} ${100 - pCorrect}`} stroke-dashoffset="0" />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#ef4444" stroke-width="3.5"
            stroke-dasharray={`${pIncorrect} ${100 - pIncorrect}`} stroke-dashoffset={`${-pCorrect}`} />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#f59e0b" stroke-width="3.5"
            stroke-dasharray={`${pAmbiguous} ${100 - pAmbiguous}`} stroke-dashoffset={`${-(pCorrect + pIncorrect)}`} />
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#8b5cf6" stroke-width="3.5"
            stroke-dasharray={`${pBlocked} ${100 - pBlocked}`} stroke-dashoffset={`${-(pCorrect + pIncorrect + pAmbiguous)}`} />
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-2xl font-black text-white">{total}</div>
          <div class="text-[10px] text-[#64748b]">platforms</div>
        </div>
      </div>
      <div class="flex flex-wrap gap-x-4 gap-y-1 mt-3 text-xs text-[#94a3b8] justify-center">
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>{t.chartCorrect}</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>{t.chartIncorrect}</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>{t.chartAmbiguous}</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#8b5cf6]"></span>{t.chartBlocked}</span>
      </div>
    </div>
  </div>
</section>

<!-- Category Bar Chart -->
<section class="max-w-6xl mx-auto px-6 mb-12">
  <div class="bg-[#111827] rounded-2xl p-6 md:p-8 border border-[#1e293b]">
    <h2 class="text-lg font-bold mb-6">{lang === 'uk' ? 'Результати за категорією' : 'Results by Category'}</h2>
    <div class="space-y-3">
      {catStats.map(cat => {
        const maxLen = Math.max(...catStats.map(c => c.total));
        const scale = 100 / maxLen;
        return (
          <div class="flex items-center gap-3">
            <div class="w-32 md:w-44 text-xs text-[#94a3b8] text-right truncate flex-shrink-0">{cat.name}</div>
            <div class="flex-1 flex h-5 rounded-full overflow-hidden bg-[#0a0e1a]">
              {cat.correct > 0 && <div class="bg-[#22c55e] h-full" style={`width: ${cat.correct * scale}%`}></div>}
              {cat.incorrect > 0 && <div class="bg-[#ef4444] h-full" style={`width: ${cat.incorrect * scale}%`}></div>}
              {cat.ambiguous > 0 && <div class="bg-[#f59e0b] h-full" style={`width: ${cat.ambiguous * scale}%`}></div>}
            </div>
            <div class="w-6 text-xs text-[#64748b] flex-shrink-0">{cat.total}</div>
          </div>
        );
      })}
    </div>
    <div class="flex gap-4 mt-4 text-xs text-[#64748b]">
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>{t.chartCorrect}</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#ef4444]"></span>{t.chartIncorrect}</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span>{t.chartAmbiguous}</span>
    </div>
  </div>
</section>

<!-- Media Framing (GDELT) -->
<section id="media-framing" class="max-w-6xl mx-auto px-6 mb-12">
  <div class="bg-[#111827] border border-[#1e293b] rounded-2xl p-8 md:p-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">{t.framingMediaTitle} — 154K {lang === 'uk' ? 'статей' : 'Articles'}</h2>
    <p class="text-[#94a3b8] mb-6">{lang === 'uk'
      ? 'GDELT, 2015-2026. 154K статей проскановано, 8,472 верифіковано LLM. Виключаючи російські ЗМІ — жодне велике міжнародне видання не підтримує російську позицію.'
      : 'GDELT, 2015–2026. 154K articles scanned, 8,472 LLM-verified. Excluding Russian media — zero major international outlets endorse Russian sovereignty framing.'
    }</p>

    <!-- Pipeline infographic -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
      <div class="text-center p-3 rounded-lg bg-[#0a0e1a] border border-[#1e293b]">
        <div class="text-2xl font-black text-white">154K</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'статей проскановано' : 'articles scanned'}</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-[#0a0e1a] border border-[#1e293b]">
        <div class="text-2xl font-black text-white">8,472</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'верифіковано LLM' : 'LLM-verified'}</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-[#0a0e1a] border border-[#22c55e]/30">
        <div class="text-2xl font-black text-[#22c55e]">99.5%</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'міжнар. ЗМІ — коректно' : 'intl media — correct'}</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-[#0a0e1a] border border-[#ef4444]/30">
        <div class="text-2xl font-black text-[#ef4444]">0.5%</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'справжні порушення' : 'genuine violations'}</div>
      </div>
    </div>

    <!-- Filter toggle -->
    <div class="flex flex-wrap items-center gap-1.5 mb-5">
      <button data-media-filter="international" class="media-filter-btn px-3 py-1.5 text-xs rounded-lg bg-[#0057b7] text-white font-medium transition-all">
        {lang === 'uk' ? 'Міжнародні' : 'International'}
      </button>
      <button data-media-filter="ukrainian" class="media-filter-btn px-3 py-1.5 text-xs rounded-lg bg-[#1e293b] text-[#94a3b8] font-medium transition-all hover:bg-[#1e293b]/80">
        {lang === 'uk' ? 'Українські' : 'Ukrainian'}
      </button>
      <button data-media-filter="russian" class="media-filter-btn px-3 py-1.5 text-xs rounded-lg bg-[#1e293b] text-[#94a3b8] font-medium transition-all hover:bg-[#1e293b]/80">
        {lang === 'uk' ? 'Російські' : 'Russian'}
      </button>
      <button data-media-filter="all" class="media-filter-btn px-3 py-1.5 text-xs rounded-lg bg-[#1e293b] text-[#94a3b8] font-medium transition-all hover:bg-[#1e293b]/80">
        {lang === 'uk' ? 'Усі' : 'All'}
      </button>
      <span class="text-[10px] text-[#64748b] ml-2" id="media-toggle-hint">
        {lang === 'uk' ? 'BBC, Reuters, Al Jazeera та ін.' : 'BBC, Reuters, Al Jazeera, etc.'}
      </span>
    </div>

    <!-- Stats row -->
    <div class="flex gap-3 mb-6">
      <div class="flex-1 text-center p-3 rounded-lg bg-[#22c55e]/10 border border-[#22c55e]/20">
        <div class="text-2xl font-bold text-[#22c55e] transition-all" id="media-stat-ua">{mediaTotals.international.ukraine.toLocaleString()}</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'Україна' : 'Ukraine'}</div>
      </div>
      <div class="flex-1 text-center p-3 rounded-lg bg-[#ef4444]/10 border border-[#ef4444]/20">
        <div class="text-2xl font-bold text-[#ef4444] transition-all" id="media-stat-ru">{mediaTotals.international.russia.toLocaleString()}</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'Росія (LLM)' : 'Russia (LLM)'}</div>
      </div>
      <div class="flex-1 text-center p-3 rounded-lg bg-[#f59e0b]/10 border border-[#f59e0b]/20">
        <div class="text-2xl font-bold text-[#f59e0b] transition-all" id="media-stat-disp">{mediaTotals.international.disputed.toLocaleString()}</div>
        <div class="text-[10px] text-[#64748b]">{lang === 'uk' ? 'Цитують обидві сторони' : 'Citing both sides'}</div>
      </div>
    </div>

    <!-- Line chart -->
    <div class="mb-6">
      <div class="text-xs text-[#64748b] mb-2">{lang === 'uk' ? 'Фреймінг суверенітету у міжнародних ЗМІ (LLM-скориговано)' : 'Sovereignty framing in international media (LLM-corrected)'}</div>
      <div class="relative" style="height: 320px;">
        <canvas id="media-chart" class="w-full h-full"></canvas>
      </div>
      <div class="flex gap-4 mt-2 text-xs text-[#94a3b8]">
