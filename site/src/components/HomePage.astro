          {t.toolCTA}
        </a>
      </div>
      <div>
        <h3 class="text-sm font-bold text-[#64748b] uppercase tracking-wider mb-3">{t.toolCliTitle}</h3>
        <div class="bg-[#0a0e1a] rounded-lg p-4 border border-[#1e293b] font-mono text-xs space-y-2">
          <div class="text-[#64748b]"># {lang === 'uk' ? 'Класифікувати зображення' : 'Classify an image'}</div>
          <div class="text-[#e2e8f0]">sovereignmap --crimea screenshot.png</div>
          <div class="mt-3 text-[#64748b]"># {lang === 'uk' ? 'Сканувати відео' : 'Scan a video'}</div>
          <div class="text-[#e2e8f0]">sovereignmap --crimea --video clip.mp4</div>
