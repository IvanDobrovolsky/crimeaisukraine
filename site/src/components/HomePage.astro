<script define:vars={{ mediaFilters, mediaTotals, mediaViolatorsByFilter, academic }}>
var currentFilter = 'international';

function lerp(a, b, t) { return a + (b - a) * t; }
function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

function drawChartFrame(id, pts, mx, events, p) {
  var c = document.getElementById(id);
  if (!c) return;
  var ctx = c.getContext('2d');
  var W = c.width = c.offsetWidth * 2;
  var H = c.height = c.offsetHeight * 2;
  ctx.scale(2, 2);
  var w = W/2, h = H/2;
  var cw = w-p.l-p.r, ch = h-p.t-p.b;
  ctx.fillStyle = '#111827';
  ctx.fillRect(0,0,w,h);
  if(!pts.length) return;
  ctx.strokeStyle='#1e293b'; ctx.lineWidth=0.5;
  for(var i=0;i<=4;i++){var gy=p.t+ch*(1-i/4); ctx.beginPath();ctx.moveTo(p.l,gy);ctx.lineTo(w-p.r,gy);ctx.stroke(); ctx.fillStyle='#64748b';ctx.font='9px sans-serif'; var v=Math.round(mx*i/4); ctx.fillText(v>=1000?(v/1000).toFixed(1)+'K':v+'',2,gy+3);}
  var n=Math.max(pts.length-1,1);
  pts.forEach(function(pt,i){var x=p.l+(i/n)*cw; if(i%2===0||pts.length<=8){ctx.fillStyle='#64748b';ctx.font='9px sans-serif';ctx.fillText(pt.y,x-12,h-6);}});
  (events||[]).forEach(function(ey){var idx=-1;pts.forEach(function(pt,i){if(pt.y===ey)idx=i;});if(idx>=0){var x=p.l+(idx/n)*cw;ctx.strokeStyle='#ffd700';ctx.lineWidth=0.8;ctx.setLineDash([4,3]);ctx.beginPath();ctx.moveTo(x,p.t);ctx.lineTo(x,p.t+ch);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='#ffd700';ctx.font='8px sans-serif';ctx.fillText(ey,x+2,p.t+10);}});
  function line(key,color,fill){ctx.beginPath();pts.forEach(function(pt,i){var x=p.l+(i/n)*cw;var y=p.t+ch*(1-pt[key]/mx);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});var lx=p.l+cw;ctx.lineTo(lx,p.t+ch);ctx.lineTo(p.l,p.t+ch);ctx.closePath();ctx.fillStyle=fill;ctx.fill();ctx.beginPath();ctx.strokeStyle=color;ctx.lineWidth=2;pts.forEach(function(pt,i){var x=p.l+(i/n)*cw;var y=p.t+ch*(1-pt[key]/mx);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});ctx.stroke();pts.forEach(function(pt,i){var x=p.l+(i/n)*cw;var y=p.t+ch*(1-pt[key]/mx);ctx.beginPath();ctx.arc(x,y,2.5,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();});}
  line('ua','#22c55e','rgba(34,197,94,0.08)');
  line('ru','#ef4444','rgba(239,68,68,0.08)');
  line('disp','#f59e0b','rgba(245,158,11,0.05)');
}

function dataToPts(data) {
  return Object.keys(data).sort().map(function(y){var d=data[y]; return {y:y, ua:d.ukraine||0, ru:d.russia||0, disp:d.disputed||0};}).filter(function(x){return x.ua+x.ru+x.disp>0;});
}

function drawChart(id, data, events) {
  var pts = dataToPts(data);
  if(!pts.length) return;
  var mx = Math.max.apply(null, pts.map(function(x){return Math.max(x.ua,x.ru,x.disp);})) * 1.15;
  drawChartFrame(id, pts, mx, events, {t:15, r:15, b:28, l:45});
}

function animateChart(id, fromData, toData, events) {
  var fromPts = dataToPts(fromData);
  var toPts = dataToPts(toData);
  if (!fromPts.length || !toPts.length) { drawChart(id, toData, events); return; }
  var mxFrom = Math.max.apply(null, fromPts.map(function(x){return Math.max(x.ua,x.ru,x.disp);})) * 1.15;
  var mxTo = Math.max.apply(null, toPts.map(function(x){return Math.max(x.ua,x.ru,x.disp);})) * 1.15;
  var dur = 600, start = null, pad = {t:15, r:15, b:28, l:45};
  function frame(ts) {
    if (!start) start = ts;
    var raw = Math.min((ts - start) / dur, 1), t = easeOut(raw);
    var mx = lerp(mxFrom, mxTo, t);
    var interpPts = toPts.map(function(pt, i) {
      var fp = fromPts[i] || {y: pt.y, ua: 0, ru: 0, disp: 0};
      return {y: pt.y, ua: lerp(fp.ua, pt.ua, t), ru: lerp(fp.ru, pt.ru, t), disp: lerp(fp.disp, pt.disp, t)};
    });
    drawChartFrame(id, interpPts, mx, events, pad);
    if (raw < 1) requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
}

var filterHints = {
  international: 'BBC, Reuters, Al Jazeera, etc.',
  ukrainian: 'Kyiv Post, UNIAN, Ukrinform, etc.',
  russian: 'RIA, TASS, Sputnik, etc.',
  all: 'All 154K articles from GDELT'
};

function renderViolators(filter) {
  var list = document.getElementById('media-violators-list');
  var countEl = document.getElementById('media-violators-count');
  if (!list) return;
  var items = mediaViolatorsByFilter[filter] || mediaViolatorsByFilter.international || [];
  if (countEl) countEl.textContent = '(' + items.length + (items.length >= 100 ? '+' : '') + ')';
  list.style.opacity = '0';
  setTimeout(function() {
    list.innerHTML = '';
    items.slice(0, 50).forEach(function(v) {
      var row = document.createElement('div');
      row.className = 'flex items-center gap-2 text-[10px] py-1 border-b border-[#1e293b]/30';
      var country = document.createElement('span');
      country.className = 'text-[#ef4444] flex-shrink-0 w-16';
      country.textContent = v.country || '?';
      var link = document.createElement('a');
      link.href = v.url;
      link.target = '_blank';
      link.rel = 'noopener';
      link.className = 'text-[#94a3b8] hover:text-white truncate';
      link.textContent = v.domain + ' — ' + (v.signals || []).slice(0, 2).join(', ');
      row.appendChild(country);
      row.appendChild(link);
      list.appendChild(row);
    });
    list.style.transition = 'opacity 0.3s ease';
    list.style.opacity = '1';
  }, 150);
}

function setMediaFilter(filter) {
  if (filter === currentFilter) return;
  var prevData = mediaFilters[currentFilter];
  currentFilter = filter;
  var newData = mediaFilters[filter];
  var totals = mediaTotals[filter];
  // Update buttons
  document.querySelectorAll('.media-filter-btn').forEach(function(btn) {
    var f = btn.getAttribute('data-media-filter');
    btn.className = 'media-filter-btn px-3 py-1.5 text-xs rounded-lg font-medium transition-all ' +
      (f === filter ? 'bg-[#0057b7] text-white' : 'bg-[#1e293b] text-[#94a3b8] hover:bg-[#1e293b]/80');
  });
  // Update stats
  var ua = document.getElementById('media-stat-ua');
  var ru = document.getElementById('media-stat-ru');
  var disp = document.getElementById('media-stat-disp');
  if (ua) ua.textContent = (totals.ukraine || 0).toLocaleString();
  if (ru) ru.textContent = (totals.russia || 0).toLocaleString();
  if (disp) disp.textContent = (totals.disputed || 0).toLocaleString();
  // Update hint
  var hint = document.getElementById('media-toggle-hint');
  if (hint) hint.textContent = filterHints[filter] || '';
  // Animate chart
  animateChart('media-chart', prevData, newData, ['2022']);
  // Update violators
  renderViolators(filter);
}

// Init filter buttons
setTimeout(function() {
  document.querySelectorAll('.media-filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      setMediaFilter(btn.getAttribute('data-media-filter'));
    });
  });
  renderViolators('international');
}, 50);

var acadData = academic.by_year_llm || academic.by_year;
setTimeout(function(){drawChart('media-chart',mediaFilters.international,['2022']);drawChart('academic-chart',acadData,['2014','2022']);},100);
window.addEventListener('resize',function(){drawChart('media-chart',mediaFilters[currentFilter],['2022']);drawChart('academic-chart',acadData,['2014','2022']);});
</script>
